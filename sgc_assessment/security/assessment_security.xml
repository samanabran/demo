<?xml version="1.0" encoding="utf-8"?>
<odoo>

        <!-- Assessment Groups -->
        <record id="group_assessment_user" model="res.groups">
            <field name="name">Assessment User</field>
        </record>

        <record id="group_assessment_viewer" model="res.groups">
            <field name="name">Assessment Viewer</field>
            <field name="implied_ids" eval="[(4, ref('group_assessment_user'))]"/>
        </record>

        <record id="group_assessment_reviewer" model="res.groups">
            <field name="name">Assessment Reviewer</field>
            <field name="implied_ids" eval="[(4, ref('group_assessment_viewer'))]"/>
        </record>

        <record id="group_assessment_manager" model="res.groups">
            <field name="name">Assessment Manager</field>
            <field name="implied_ids" eval="[(4, ref('group_assessment_reviewer'))]"/>
        </record>
</odoo>
