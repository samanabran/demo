<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Human Review Form View -->
    <record id="view_assessment_human_review_form" model="ir.ui.view">
        <field name="name">assessment.human.review.form</field>
        <field name="model">assessment.human.review</field>
        <field name="arch" type="xml">
            <form string="Human Review">
                <header>
                    <button name="action_complete" string="Complete Review" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="candidate_id" placeholder="Candidate..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="reviewer_id"/>
                            <field name="review_date"/>
                        </group>
                        <group>
                            <field name="recommendation" widget="selection"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Ratings">
                        <group>
                            <field name="rating_technical" widget="selection"/>
                            <field name="rating_communication" widget="selection"/>
                        </group>
                        <group>
                            <field name="rating_cultural_fit" widget="selection"/>
                        </group>
                    </group>
                    <group string="AI Override">
                        <field name="override_ai_score"/>
                        <field name="override_reason" invisible="not override_ai_score" required="override_ai_score"/>
                    </group>
                    <field name="reviewer_notes" placeholder="Enter detailed review notes..." nolabel="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Human Review Tree View -->
    <record id="view_assessment_human_review_tree" model="ir.ui.view">
        <field name="name">assessment.human.review.tree</field>
        <field name="model">assessment.human.review</field>
        <field name="arch" type="xml">
            <list>
                <field name="candidate_id"/>
                <field name="reviewer_id"/>
                <field name="review_date"/>
                <field name="recommendation"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Human Review Search View -->
    <record id="view_assessment_human_review_search" model="ir.ui.view">
        <field name="name">assessment.human.review.search</field>
        <field name="model">assessment.human.review</field>
        <field name="arch" type="xml">
            <search>
                <field name="candidate_id"/>
                <field name="reviewer_id"/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Completed" name="completed" domain="[('state','=','completed')]"/>
            </search>
        </field>
    </record>

    <!-- Human Review Action -->
    <record id="action_assessment_human_review" model="ir.actions.act_window">
        <field name="name">Human Reviews</field>
        <field name="res_model">assessment.human.review</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_assessment_human_review_search"/>
    </record>
</odoo>
