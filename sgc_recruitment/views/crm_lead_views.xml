<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="crm_lead_view_form_inherit_recruitment" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.recruitment</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_recruitment_applicant" string="Create Recruitment Applicant" type="object" class="oe_highlight" invisible="stage_id.is_won != True or type != 'opportunity'"/>
            </xpath>
        </field>
    </record>
</odoo>
