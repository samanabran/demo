<odoo>

    <!-- =================================================================
         Uniform SGC TECH AI icons for native Odoo 19 root menus.
         Each record overrides:
           - web_icon        : Apps grid (path to PNG inside this module)
           - web_icon_data   : Appsbar / home menu (binary, populated from
                               the same PNG via type="file" file ref)
         The image files live in this module at static/icons/<name>.png
         and share the same navy/gold brand palette produced by the bulk
         slice step. Re-installing this module is safe; upgrades re-apply.
         ================================================================= -->
    <record id="mail.menu_root_discuss" model="ir.ui.menu">
        <field name="web_icon">sgc_ui_brand_palette,static/icons/core_discuss.png</field>
        <field name="web_icon_data" type="file">static/icons/core_discuss.png</field>
    </record>
