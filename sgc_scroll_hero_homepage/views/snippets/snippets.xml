<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="scroll_hero_snippets" inherit_id="website.snippets" name="Storytelling Snippets">
    <xpath expr="//snippets[@id='snippet_structure']" position="after">
      <snippets id="snippet_storytelling" string="Storytelling">
        <t t-snippet="sgc_scroll_hero_homepage.s_re_scroll_hero"
           t-thumbnail="/sgc_scroll_hero_homepage/static/src/img/s_re_scroll_hero_thumb.jpg"
           t-name="Scroll Story Hero"/>
      </snippets>
    </xpath>
  </template>
</odoo>
