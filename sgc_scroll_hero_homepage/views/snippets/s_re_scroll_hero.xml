<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="s_re_scroll_hero" name="Scroll Story Hero">
<section class="s_re_scroll_hero o_re_scroll_hero"
         data-snippet="s_re_scroll_hero"
         data-name="Scroll Story Hero"
         data-pin-height="450"
         data-frame-count="121"
         data-frame-base="/sgc_scroll_hero_homepage/static/src/img/frames/frame_"
         data-frame-digits="4"
         data-frame-ext=".jpg">

    <!--
        GSAP + ScrollTrigger are not loaded anywhere else in this Odoo
        instance. Inject them from CDN exactly once, even if this snippet
        is dropped onto the page more than once: the loading flag covers
        the race between two instances both finding window.gsap undefined
        before the first request resolves.
    -->
    <script>
        (function () {
            if (window.gsap || window.__sgcGsapLoading) {
                return;
            }
            window.__sgcGsapLoading = true;
            function loadScript(src, cb) {
                var s = document.createElement('script');
                s.src = src;
                s.onload = cb;
                document.head.appendChild(s);
            }
            loadScript('https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js', function () {
                loadScript('https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js', function () {
                    document.dispatchEvent(new Event('sgc:gsap-ready'));
                });
            });
        })();
    </script>

    <div class="o_re_scroll_hero__pin">
        <canvas class="o_re_scroll_hero__canvas"></canvas>

        <div class="o_re_scroll_hero__loader">Loading 0%</div>

        <div class="o_re_scroll_hero__captions">
            <div class="o_re_scroll_hero__caption" data-progress-start="0.00" data-progress-end="0.15">
                <h1>Every home has a story.</h1>
            </div>
            <div class="o_re_scroll_hero__caption" data-progress-start="0.35" data-progress-end="0.50">
                <h1>Yours is about to begin.</h1>
            </div>
            <div class="o_re_scroll_hero__caption" data-progress-start="0.70" data-progress-end="0.85">
                <h1>Let's find where it starts.</h1>
            </div>
        </div>

        <div class="o_re_scroll_hero__search" data-progress-start="0.92" data-progress-end="1.00">
            <form class="card shadow-lg p-3 p-md-4" method="get" action="/offplan/properties">
                <div class="row g-2 align-items-center">
                    <div class="col-12 col-md-4">
                        <div class="input-group">
                            <span class="input-group-text"><span class="fa fa-search"></span></span>
                            <input type="text" class="form-control" name="search"
                                   placeholder="Enter a city or property name"/>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <select class="form-select" name="property_type">
                            <option value="">Any Type</option>
                            <option value="residential">Residential</option>
                            <option value="commercial">Commercial</option>
                            <option value="industrial">Industrial</option>
                            <option value="land">Land</option>
                        </select>
                    </div>
                    <div class="col-6 col-md-3">
                        <select class="form-select" name="state">
                            <option value="available" selected="selected">Available</option>
                            <option value="booked">Booked</option>
                            <option value="sold">Sold</option>
                            <option value="rented">Rented</option>
                            <option value="maintenance">Under Maintenance</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-2">
                        <button type="submit" class="btn btn-primary w-100">Search Properties</button>
                    </div>
                </div>
            </form>
        </div>

        <div class="o_re_scroll_hero__scrollhint">
            <span>Scroll to begin</span>
            <span class="fa fa-chevron-down o_re_scroll_hero__chevron"></span>
        </div>
    </div>
</section>
</template>

</odoo>
