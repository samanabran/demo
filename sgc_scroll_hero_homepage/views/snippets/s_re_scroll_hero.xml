<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="s_re_scroll_hero" name="Scroll Story Hero">
    <section data-snippet="s_re_scroll_hero" data-name="Scroll Story Hero"
             data-frame-count="240" data-pin-height="600"
             class="s_re_scroll_hero position-relative p-0">

      <!-- Guarded CDN + font injection, scoped to this snippet instance only.
           Sitewide assets_frontend bundle is deliberately NOT used for GSAP,
           per spec: it must only load on pages that actually contain this
           snippet. -->
      <script>
        (function () {
          function loadScript(src, cb) {
            var s = document.createElement('script');
            s.src = src;
            s.onload = cb;
            document.head.appendChild(s);
          }
          function announceReady() {
            document.dispatchEvent(new Event('sgc:gsap-ready'));
          }
          if (window.gsap &amp;&amp; window.ScrollTrigger) {
            announceReady();
          } else if (window.gsap &amp;&amp; !window.ScrollTrigger) {
            loadScript('https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js', announceReady);
          } else {
            loadScript('https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js', function () {
              loadScript('https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js', announceReady);
            });
          }
          if (!document.querySelector('link[data-sgc-font="fraunces"]')) {
            var link = document.createElement('link');
            link.rel = 'stylesheet';
            link.setAttribute('data-sgc-font', 'fraunces');
            link.href = 'https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600&amp;display=swap';
            document.head.appendChild(link);
          }
        })();
      </script>

      <div class="s_re_hero_stage">
        <canvas class="s_re_hero_canvas" aria-hidden="true"/>

        <!-- Dark gradient overlay behind caption/search during the final
             beat, since the last frame (interior bedroom) is sharp/detailed
             rather than a soft neutral background. -->
        <div class="s_re_hero_overlay_final" aria-hidden="true"/>

        <!-- Single reusable caption element, text/position/opacity driven
             entirely by scroll_hero.js per story beat. -->
        <div class="s_re_hero_caption" role="status" aria-live="polite"/>

        <div class="s_re_hero_search_wrap">
          <form method="get" action="/offplan/properties" class="s_re_hero_search_form" aria-label="Property search">
            <div class="s_re_hero_search_segment s_re_hero_search_segment--location">
              <span class="s_re_hero_search_icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
              </span>
              <input type="text" name="search" class="form-control s_re_hero_search_input"
                     placeholder="City or property name" aria-label="City or property name" tabindex="-1"/>
            </div>

            <span class="s_re_hero_search_divider" aria-hidden="true"></span>

            <div class="s_re_hero_search_segment s_re_hero_search_segment--type">
              <span class="s_re_hero_search_icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9.5 12 2l9 7.5"/><path d="M5 10v10h14V10"/><path d="M9 20v-6h6v6"/></svg>
              </span>
              <select name="property_type" class="form-select s_re_hero_search_input" aria-label="Property type" tabindex="-1">
                <option value="">Any type</option>
                <option value="residential">Residential</option>
                <option value="commercial">Commercial</option>
                <option value="industrial">Industrial</option>
                <option value="land">Land</option>
              </select>
            </div>

            <span class="s_re_hero_search_divider" aria-hidden="true"></span>

            <div class="s_re_hero_search_segment s_re_hero_search_segment--status">
              <span class="s_re_hero_search_icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
              </span>
              <select name="state" class="form-select s_re_hero_search_input" aria-label="Status" tabindex="-1">
                <option value="available" selected="selected">Available</option>
                <option value="booked">Booked</option>
                <option value="sold">Sold</option>
                <option value="rented">Rented</option>
                <option value="under_maintenance">Under Maintenance</option>
              </select>
            </div>

            <button type="submit" class="s_re_hero_search_btn" tabindex="-1">
              <span class="s_re_hero_search_icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
              </span>
              <span class="s_re_hero_search_btn_label">Search Properties</span>
            </button>
          </form>
        </div>

        <div class="s_re_hero_scroll_hint">
          <span>Scroll to begin</span>
          <i class="fa fa-chevron-down s_re_hero_chevron" aria-hidden="true"/>
        </div>

        <div class="s_re_hero_loading" aria-hidden="true">
          <span>Loading…</span>
        </div>
      </div>
    </section>
  </template>
</odoo>
