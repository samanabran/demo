<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="s_re_scroll_hero" name="Scroll Story Hero">
    <section data-snippet="s_re_scroll_hero" data-name="Scroll Story Hero"
             data-frame-count="240" data-pin-height="600"
             class="s_re_scroll_hero position-relative p-0">

      <!-- Guarded CDN + font injection, scoped to this snippet instance only.
           Sitewide assets_frontend bundle is deliberately NOT used for GSAP,
           per spec: it must only load on pages that actually contain this
           snippet. -->
      <script>
        (function () {
          function loadScript(src, cb) {
            var s = document.createElement('script');
            s.src = src;
            s.onload = cb;
            document.head.appendChild(s);
          }
          function announceReady() {
            document.dispatchEvent(new Event('sgc:gsap-ready'));
          }
          if (window.gsap &amp;&amp; window.ScrollTrigger) {
            announceReady();
          } else if (window.gsap &amp;&amp; !window.ScrollTrigger) {
            loadScript('https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js', announceReady);
          } else {
            loadScript('https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js', function () {
              loadScript('https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js', announceReady);
            });
          }
          if (!document.querySelector('link[data-sgc-font="fraunces"]')) {
            var link = document.createElement('link');
            link.rel = 'stylesheet';
            link.setAttribute('data-sgc-font', 'fraunces');
            link.href = 'https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600&amp;display=swap';
            document.head.appendChild(link);
          }
        })();
      </script>

      <div class="s_re_hero_stage">
        <canvas class="s_re_hero_canvas" aria-hidden="true"/>

        <!-- Dark gradient overlay behind caption/search during the final
             beat, since the last frame (interior bedroom) is sharp/detailed
             rather than a soft neutral background. -->
        <div class="s_re_hero_overlay_final" aria-hidden="true"/>

        <!-- Single reusable caption element, text/position/opacity driven
             entirely by scroll_hero.js per story beat. -->
        <div class="s_re_hero_caption" role="status" aria-live="polite"/>

        <div class="s_re_hero_search_wrap">
          <form method="get" action="/offplan/properties" class="s_re_hero_search_form container">
            <div class="row g-2 justify-content-center align-items-center">
              <div class="col-12 col-md-4">
                <input type="text" name="search" class="form-control"
                       placeholder="Enter a city or property name"/>
              </div>
              <div class="col-6 col-md-3">
                <select name="property_type" class="form-select">
                  <option value="">Any Type</option>
                  <option value="residential">Residential</option>
                  <option value="commercial">Commercial</option>
                  <option value="industrial">Industrial</option>
                  <option value="land">Land</option>
                </select>
              </div>
              <div class="col-6 col-md-3">
                <select name="state" class="form-select">
                  <option value="available" selected="selected">Available</option>
                  <option value="booked">Booked</option>
                  <option value="sold">Sold</option>
                  <option value="rented">Rented</option>
                  <option value="under_maintenance">Under Maintenance</option>
                </select>
              </div>
              <div class="col-12 col-md-2">
                <button type="submit" class="btn btn-primary w-100">Search Properties</button>
              </div>
            </div>
          </form>
        </div>

        <div class="s_re_hero_scroll_hint">
          <span>Scroll to begin</span>
          <i class="fa fa-chevron-down s_re_hero_chevron"/>
        </div>

        <div class="s_re_hero_loading" aria-hidden="true">
          <span>Loading…</span>
        </div>
      </div>
    </section>
  </template>
</odoo>
