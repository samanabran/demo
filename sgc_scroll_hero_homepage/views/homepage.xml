<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

    <!--
        This is a brand new page/view — it does not touch the existing
        `website.homepage` view (id key "website.homepage") at all. That
        original page stays exactly as it was, just no longer linked from
        `website.homepage_url` (see the <record model="website"> below),
        so it can be restored instantly by clearing that field again or by
        uninstalling this module (handled by hooks.py::uninstall_hook).
    -->
    <template id="new_homepage" name="Property Scroll Hero Homepage">
        <t t-call="website.layout">
            <t t-set="pageName" t-value="'homepage'"/>
            <div id="wrap" class="oe_structure">

                <t t-call="sgc_scroll_hero_homepage.s_re_scroll_hero"/>

                <section class="s_re_featured_properties pt56 pb56">
                    <div class="container">
                        <h2 class="text-center mb-4">Featured Properties</h2>

                        <t t-set="featured_properties"
                           t-value="request.env['property.details'].sudo().search(
                                [('is_published_website', '=', True)],
                                order='create_date desc', limit=6)"/>

                        <div class="row g-4" t-if="featured_properties">
                            <div class="col-12 col-sm-6 col-lg-4" t-foreach="featured_properties" t-as="prop">
                                <div class="property-card card h-100 shadow-sm">
                                    <div class="position-relative overflow-hidden" style="height: 220px;">
                                        <img t-if="prop.image_512"
                                             t-att-src="'/web/image/property.details/%s/image_512' % prop.id"
                                             class="card-img-top" style="height:100%;width:100%;object-fit:cover;"
                                             t-att-alt="prop.name"/>
                                        <img t-else=""
                                             t-att-src="'/web/static/src/img/placeholder.png'"
                                             class="card-img-top" style="height:100%;width:100%;object-fit:cover;"/>
                                    </div>
                                    <div class="card-body d-flex flex-column">
                                        <h5 class="card-title" t-esc="prop.name"/>
                                        <p class="text-muted small mb-2" t-if="prop.city">
                                            <span class="fa fa-map-marker" title="Location"></span>
                                            <span t-esc="prop.city"/>
                                        </p>
                                        <div class="mb-3 d-flex text-muted small">
                                            <span class="me-3">
                                                <span class="fa fa-bed" title="Bedrooms"></span>
                                                <t t-esc="prop.bedrooms or 0"/>
                                            </span>
                                            <span class="me-3">
                                                <span class="fa fa-bath" title="Bathrooms"></span>
                                                <t t-esc="prop.bathrooms or 0"/>
                                            </span>
                                            <span t-if="prop.area">
                                                <span class="fa fa-arrows-alt" title="Area"></span>
                                                <t t-esc="prop.area"/> sqft
                                            </span>
                                        </div>
                                        <div class="d-flex justify-content-between align-items-center mt-auto">
                                            <h4 class="text-primary mb-0" t-if="prop.sale_lease == 'lease' and (prop.rent_price or prop.price)">
                                                <t t-esc="'AED %s/mo' % '{:,.0f}'.format(prop.rent_price or prop.price)"/>
                                            </h4>
                                            <h4 class="text-primary mb-0" t-elif="prop.sale_price or prop.price">
                                                <t t-esc="'AED %s' % '{:,.0f}'.format(prop.sale_price or prop.price)"/>
                                            </h4>
                                            <a t-att-href="'/offplan/property/%s' % prop.id"
                                               class="btn btn-sm btn-outline-primary">View Details</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="alert alert-info text-center" t-if="not featured_properties">
                            No published properties yet — publish some from the Property Management app to
                            feature them here.
                        </div>
                    </div>
                </section>

            </div>
        </t>
    </template>

    <record id="website_page_new_homepage" model="website.page">
        <field name="url">/property-showcase-home</field>
        <field name="website_id" ref="website.default_website"/>
        <field name="view_id" ref="new_homepage"/>
        <field name="is_published">True</field>
        <field name="website_indexed">False</field>
    </record>

    <!--
        This single field write is what actually makes the new page the
        homepage: Odoo's own website controller reroutes "/" to
        homepage_url whenever it's set to anything other than "/". It is
        the standard, fully-reversible Odoo mechanism for this — no
        existing view or page record is modified or deleted.
    -->
    <record id="website.default_website" model="website">
        <field name="homepage_url">/property-showcase-home</field>
    </record>

</data>
</odoo>
