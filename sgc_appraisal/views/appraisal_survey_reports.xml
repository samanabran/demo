<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Report action for survey form -->
    <record id="appraisal_survey_form_report" model="ir.actions.report">
        <field name="name">Appraisal Survey Form Report</field>
        <field name="model">appraisal.survey.form</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sgc_appraisal.appraisal_survey_form_report_template</field>
        <field name="report_file">sgc_appraisal.appraisal_survey_form_report_template</field>
        <field name="binding_model_id" ref="model_appraisal_survey_form"/>
    </record>

    <!-- Report action for survey response -->
    <record id="appraisal_survey_response_report" model="ir.actions.report">
        <field name="name">Appraisal Survey Response Report</field>
        <field name="model">appraisal.survey.response</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sgc_appraisal.appraisal_survey_response_report_template</field>
        <field name="report_file">sgc_appraisal.appraisal_survey_response_report_template</field>
        <field name="binding_model_id" ref="model_appraisal_survey_response"/>
    </record>

    <!-- Minimal QWeb template for survey form report -->
    <template id="appraisal_survey_form_report_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <div class="page">
                    <h1 t-esc="doc.name"/>
                    <p t-esc="doc.description"/>
                </div>
            </t>
        </t>
    </template>

    <!-- Minimal QWeb template for survey response report -->
    <template id="appraisal_survey_response_report_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <div class="page">
                    <h1>Survey Response</h1>
                    <p>Survey: <span t-esc="doc.survey_form_id.name"/></p>
                    <p>Respondent: <span t-esc="doc.respondent_name"/></p>
                    <p>State: <span t-esc="doc.state"/></p>
                </div>
            </t>
        </t>
    </template>
</odoo>
