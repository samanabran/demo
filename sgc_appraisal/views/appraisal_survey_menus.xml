<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ===== Window Actions ===== -->

    <!-- Survey Form Actions -->
    <record id="action_appraisal_survey_form_all" model="ir.actions.act_window">
        <field name="name">Survey Forms</field>
        <field name="res_model">appraisal.survey.form</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new appraisal survey form
            </p>
            <p>
                Use survey forms to gather feedback on employee appraisals.
                You can customize survey questions, assign respondents, and track responses.
            </p>
        </field>
    </record>

    <!-- Survey Response Actions -->
    <record id="action_appraisal_survey_response_all" model="ir.actions.act_window">
        <field name="name">Survey Responses</field>
        <field name="res_model">appraisal.survey.response</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No survey responses yet
            </p>
            <p>
                Survey responses will appear here once employees start filling out surveys.
            </p>
        </field>
    </record>

    <!-- Create Survey Wizard Action -->
    <record id="action_appraisal_survey_wizard_create" model="ir.actions.act_window">
        <field name="name">Create Survey</field>
        <field name="res_model">appraisal.survey.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Survey Bulk Actions -->
    <record id="action_appraisal_survey_bulk_action" model="ir.actions.act_window">
        <field name="name">Bulk Actions</field>
        <field name="res_model">appraisal.survey.bulk.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- ===== Report Actions ===== -->
    <!-- Reports are defined in appraisal_survey_reports.xml -->

    <!-- ===== Context Actions on Appraisal ===== -->

    <!-- Button on HR Appraisal to create survey -->
    <record id="action_create_appraisal_survey_from_appraisal" model="ir.actions.act_window">
        <field name="name">Create Survey</field>
        <field name="res_model">appraisal.survey.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_appraisal_id': active_id}</field>
    </record>

    <!-- ===== Menu Items for Appraisal Survey Module ===== -->

    <!-- Survey Forms Management - under existing Appraisal menu -->
    <menuitem id="menu_appraisal_survey_forms"
              name="Survey Forms"
              parent="hr_appraisal_menu_root"
              action="action_appraisal_survey_form_all"
              sequence="20"/>

    <!-- Survey Responses -->
    <menuitem id="menu_appraisal_survey_responses"
              name="Survey Responses"
              parent="hr_appraisal_menu_root"
              action="action_appraisal_survey_response_all"
              sequence="30"/>

    <!-- Reports Submenu -->
    <menuitem id="menu_appraisal_survey_reports"
              name="Reports"
              parent="hr_appraisal_menu_root"
              sequence="40"/>

    <menuitem id="menu_appraisal_survey_report_form"
              name="Survey Report"
              parent="menu_appraisal_survey_reports"
              action="appraisal_survey_form_report"
              sequence="1"/>

    <menuitem id="menu_appraisal_survey_report_response"
              name="Response Report"
              parent="menu_appraisal_survey_reports"
              action="appraisal_survey_response_report"
              sequence="2"/>

</odoo>
