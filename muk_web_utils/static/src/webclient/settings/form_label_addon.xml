<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-inherit="web.FormLabelHighlightText" t-inherit-mode="extension">
        <xpath expr="//label" position="inside">
            <t t-if="addonState and addonState.show">
                <span class="badge text-bg-primary oe_inline ms-2">Add-on</span>
            </t>
        </xpath>
    </t>

</templates>
