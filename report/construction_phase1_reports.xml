<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Landscape A4 paper format for wide, multi-column reports -->
    <record id="paperformat_construction_landscape" model="report.paperformat">
        <field name="name">Construction A4 Landscape</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Landscape</field>
        <field name="margin_top">32</field>
        <field name="margin_bottom">26</field>
        <field name="margin_left">7</field>
        <field name="margin_right">7</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">27</field>
        <field name="dpi">90</field>
    </record>

    <!-- IPC Report Action -->
    <record id="action_report_ipc" model="ir.actions.report">
        <field name="name">Interim Payment Certificate (IPC)</field>
        <field name="model">construction.ra.billing</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sgc_construction_management.report_ipc_template</field>
        <field name="report_file">sgc_construction_management.report_ipc_template</field>
        <field name="print_report_name">'IPC - %s' % (object.ref)</field>
        <field name="paperformat_id" ref="paperformat_construction_portrait"/>
        <field name="binding_model_id" ref="model_construction_ra_billing"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Statement of Account Report Action — Portrait (client-facing) -->
    <record id="action_report_statement_account" model="ir.actions.report">
        <field name="name">Statement of Account</field>
        <field name="model">res.partner</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sgc_construction_management.report_soa_template</field>
        <field name="report_file">sgc_construction_management.report_soa_template</field>
        <field name="print_report_name">'SOA - %s' % (object.name)</field>
        <field name="paperformat_id" ref="paperformat_construction_portrait"/>
        <field name="binding_model_id" ref="base.model_res_partner"/>
        <field name="binding_type">report</field>
    </record>

    <!-- WIP Report Action -->
    <record id="action_report_wip" model="ir.actions.report">
        <field name="name">WIP Report</field>
        <field name="model">construction.project</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sgc_construction_management.report_wip_template</field>
        <field name="report_file">sgc_construction_management.report_wip_template</field>
        <field name="print_report_name">'WIP - %s' % (object.name)</field>
        <field name="paperformat_id" ref="paperformat_construction_landscape"/>
        <field name="binding_model_id" ref="model_construction_project"/>
        <field name="binding_type">report</field>
    </record>

    <!-- VO Register Action -->
    <record id="action_report_vo_register" model="ir.actions.report">
        <field name="name">VO Register</field>
        <field name="model">construction.project</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sgc_construction_management.report_vo_register_template</field>
        <field name="report_file">sgc_construction_management.report_vo_register_template</field>
        <field name="print_report_name">'VO_Register - %s' % (object.name)</field>
        <field name="paperformat_id" ref="paperformat_construction_landscape"/>
        <field name="binding_model_id" ref="model_construction_project"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Profitability Report Action -->
    <record id="action_report_profitability" model="ir.actions.report">
        <field name="name">Project Profitability</field>
        <field name="model">construction.project</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sgc_construction_management.report_profitability_template</field>
        <field name="report_file">sgc_construction_management.report_profitability_template</field>
        <field name="print_report_name">'Profitability - %s' % (object.name)</field>
        <field name="paperformat_id" ref="paperformat_construction_landscape"/>
        <field name="binding_model_id" ref="model_construction_project"/>
        <field name="binding_type">report</field>
    </record>

    <!-- WIP Report Action (Excel) -->
    <record id="action_report_wip_xlsx" model="ir.actions.report">
        <field name="name">WIP Report (Excel)</field>
        <field name="model">construction.project</field>
        <field name="report_type">xlsx</field>
        <field name="report_name">sgc_construction_management.report_wip_xlsx</field>
        <field name="report_file">sgc_construction_management.report_wip_xlsx</field>
        <field name="print_report_name">'WIP - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_construction_project"/>
