<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="sgc_offplan_rental_property_management.RentalPropertyDashboard" owl="1">
        <div class="sgc-dashboard">

            <!-- Header -->
            <header class="sgc-header">
                <div class="sgc-header__brand">
                    <div class="sgc-header__brand-icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 21V9l9-6 9 6v12"/><path d="M9 21v-7h6v7"/>
                        </svg>
                    </div>
                    <div class="sgc-header__brand-text">
                        <div class="sgc-header__brand-name">SGC Real Estate</div>
                        <div class="sgc-header__brand-sub">Executive Dashboard</div>
                    </div>
                </div>
                <div class="sgc-header__actions">
                    <button class="sgc-icon-btn sgc-theme-toggle" t-on-click="toggleTheme" title="Toggle theme">
                        <svg class="sgc-theme-toggle__icon sgc-theme-toggle__icon--sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="4"/>
                            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
                        </svg>
                        <svg class="sgc-theme-toggle__icon sgc-theme-toggle__icon--moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                        </svg>
                    </button>
                </div>
            </header>

            <!-- Main canvas -->
            <main class="sgc-main">
                <div class="sgc-grid">

                    <!-- Row 1: Primary KPIs -->
                    <div class="sgc-kpi-row">
                        <div class="sgc-kpi" t-on-click="() => this.viewProperties('all')">
                            <div class="sgc-kpi__header">
                                <div class="sgc-kpi__label">Total Properties</div>
                                <div class="sgc-kpi__icon sgc-kpi__icon--blue">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M3 21V9l9-6 9 6v12"/><path d="M9 21v-7h6v7"/>
                                    </svg>
                                </div>
                            </div>
                            <div class="sgc-kpi__value"><t t-esc="state.total_property"/></div>
                            <div class="sgc-kpi__sub">All property records</div>
                        </div>

                        <div class="sgc-kpi" t-on-click="() => this.viewProperties('available')">
                            <div class="sgc-kpi__header">
                                <div class="sgc-kpi__label">Available</div>
                                <div class="sgc-kpi__icon sgc-kpi__icon--green">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
                                    </svg>
                                </div>
                            </div>
                            <div class="sgc-kpi__value"><t t-esc="state.avail_property"/></div>
                            <div class="sgc-kpi__sub">Ready to let or sell</div>
                            <div class="sgc-kpi__trend sgc-kpi__trend--up">
                                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 15l7-7 7 7"/></svg>
                                Available now
                            </div>
                        </div>

                        <div class="sgc-kpi">
                            <div class="sgc-kpi__header">
                                <div class="sgc-kpi__label">Sales Revenue</div>
                                <div class="sgc-kpi__icon sgc-kpi__icon--amber">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M3 3v18h18"/><path d="M7 14l4-4 4 4 5-7"/>
                                    </svg>
                                </div>
                            </div>
                            <div class="sgc-kpi__value"><t t-esc="formatCurrency(state.sold_total)"/></div>
                            <div class="sgc-kpi__sub">Total sold value</div>
                        </div>

                        <div class="sgc-kpi">
                            <div class="sgc-kpi__header">
                                <div class="sgc-kpi__label">Rental Income</div>
                                <div class="sgc-kpi__icon sgc-kpi__icon--cyan">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/>
                                    </svg>
                                </div>
                            </div>
                            <div class="sgc-kpi__value"><t t-esc="formatCurrency(state.rent_total)"/></div>
                            <div class="sgc-kpi__sub">All rent invoices</div>
                        </div>

                        <div class="sgc-kpi">
                            <div class="sgc-kpi__header">
                                <div class="sgc-kpi__label">Pending Invoices</div>
                                <div class="sgc-kpi__icon sgc-kpi__icon--red">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                                        <line x1="12" y1="9" x2="12" y2="13"/><circle cx="12" cy="17" r="0.7" fill="currentColor"/>
                                    </svg>
                                </div>
                            </div>
                            <div t-attf-class="sgc-kpi__value #{totalPendingInvoices > 0 ? 'sgc-kpi__value--critical' : ''}">
                                <t t-esc="totalPendingInvoices"/>
                            </div>
                            <div class="sgc-kpi__sub">Rent + sale unpaid</div>
                        </div>
                    </div>

                    <!-- Row 2: Secondary KPIs -->
                    <div class="sgc-kpi-row">
                        <div class="sgc-kpi" t-on-click="() => this.viewPartners('customer')">
                            <div class="sgc-kpi__header">
                                <div class="sgc-kpi__label">Customers</div>
                                <div class="sgc-kpi__icon sgc-kpi__icon--blue">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                                    </svg>
                                </div>
                            </div>
                            <div class="sgc-kpi__value"><t t-esc="state.customer_count"/></div>
                            <div class="sgc-kpi__sub">Registered customers</div>
                        </div>

                        <div class="sgc-kpi" t-on-click="() => this.viewPartners('landlord')">
                            <div class="sgc-kpi__header">
                                <div class="sgc-kpi__label">Landlords</div>
                                <div class="sgc-kpi__icon sgc-kpi__icon--amber">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                                    </svg>
                                </div>
                            </div>
                            <div class="sgc-kpi__value"><t t-esc="state.landlord_count"/></div>
                            <div class="sgc-kpi__sub">Property owners</div>
                        </div>

                        <div class="sgc-kpi">
                            <div class="sgc-kpi__header">
                                <div class="sgc-kpi__label">Projects</div>
                                <div class="sgc-kpi__icon sgc-kpi__icon--cyan">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>
                                    </svg>
                                </div>
                            </div>
                            <div class="sgc-kpi__value"><t t-esc="state.project_count"/></div>
                            <div class="sgc-kpi__sub">Active project areas</div>
                        </div>

                        <div class="sgc-kpi">
                            <div class="sgc-kpi__header">
                                <div class="sgc-kpi__label">Sub-Projects</div>
                                <div class="sgc-kpi__icon sgc-kpi__icon--green">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"/>
                                    </svg>
                                </div>
                            </div>
                            <div class="sgc-kpi__value"><t t-esc="state.subproject_count"/></div>
                            <div class="sgc-kpi__sub">Building clusters</div>
                        </div>

                        <div class="sgc-kpi">
                            <div class="sgc-kpi__header">
                                <div class="sgc-kpi__label">Regions</div>
                                <div class="sgc-kpi__icon sgc-kpi__icon--red">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <circle cx="12" cy="10" r="3"/>
                                        <path d="M12 2a8 8 0 0 1 8 8c0 5.5-8 14-8 14S4 15.5 4 10a8 8 0 0 1 8-8z"/>
                                    </svg>
                                </div>
                            </div>
                            <div class="sgc-kpi__value"><t t-esc="state.region_count"/></div>
                            <div class="sgc-kpi__sub">Geographic regions</div>
                        </div>
                    </div>

                    <!-- Row 3: Hero — type donut + contract alerts -->
                    <div class="sgc-hero-row">
                        <div class="sgc-card">
                            <div class="sgc-card__header">
                                <div>
                                    <div class="sgc-card__title">Property Type Breakdown</div>
                                    <div class="sgc-card__title-sub">Distribution by category</div>
                                </div>
                                <div class="sgc-card__toolbar">
                                    <span class="sgc-card__chip"><t t-esc="state.total_property"/> Total</span>
                                </div>
                            </div>
                            <div class="sgc-card__body">
                                <div class="sgc-chart" t-ref="typeChart"/>
                            </div>
                        </div>

                        <div class="sgc-alerts">
                            <div class="sgc-alerts__header">
                                <div class="sgc-alerts__title">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M6 8a6 6 0 1 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/>
                                        <path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/>
                                    </svg>
                                    Contract Status
                                </div>
                            </div>
                            <div class="sgc-alerts__list">
                                <div class="sgc-alert" t-on-click="() => this.viewContracts('running_contract')">
                                    <div class="sgc-alert__head">
                                        <div class="sgc-alert__name">Running Contracts</div>
                                        <span class="sgc-alert__badge sgc-alert__badge--ok"><t t-esc="state.running_contract"/></span>
                                    </div>
                                    <div class="sgc-alert__reason">Active tenancy agreements in force</div>
                                </div>
                                <div class="sgc-alert" t-on-click="() => this.viewContracts('new_contract')">
                                    <div class="sgc-alert__head">
                                        <div class="sgc-alert__name">Draft Contracts</div>
                                        <span class="sgc-alert__badge sgc-alert__badge--warning"><t t-esc="state.draft_contract"/></span>
                                    </div>
                                    <div class="sgc-alert__reason">Pending signature or approval</div>
                                </div>
                                <div class="sgc-alert sgc-alert--warning" t-on-click="() => this.viewContracts('expire_contract')">
                                    <div class="sgc-alert__head">
                                        <div class="sgc-alert__name">Expired Contracts</div>
                                        <span class="sgc-alert__badge sgc-alert__badge--critical"><t t-esc="state.expire_contract"/></span>
                                    </div>
                                    <div class="sgc-alert__reason">Require renewal or termination</div>
                                </div>
                                <div class="sgc-alert" t-on-click="() => this.viewContracts('close_contract')">
                                    <div class="sgc-alert__head">
                                        <div class="sgc-alert__name">Closed Contracts</div>
                                        <span class="sgc-alert__badge sgc-alert__badge--ok"><t t-esc="state.close_contract"/></span>
                                    </div>
                                    <div class="sgc-alert__reason">Terminated or completed</div>
                                </div>
                            </div>
                            <div class="sgc-alerts__footer" t-on-click="() => this.viewContracts('')">View All Contracts ›</div>
                        </div>
                    </div>

                    <!-- Row 4: Revenue chart + state breakdown -->
                    <div class="sgc-financial-row">
                        <div class="sgc-card">
                            <div class="sgc-card__header">
                                <div>
                                    <div class="sgc-card__title">Revenue Performance</div>
                                    <div class="sgc-card__title-sub">Rental Income vs Sales Revenue (monthly estimate)</div>
                                </div>
                            </div>
                            <div class="sgc-card__body">
                                <div class="sgc-chart" t-ref="financialChart"/>
                            </div>
                        </div>

                        <div class="sgc-card">
                            <div class="sgc-card__header">
                                <div>
                                    <div class="sgc-card__title">Portfolio Snapshot</div>
                                    <div class="sgc-card__title-sub">Properties by stage</div>
                                </div>
                            </div>
                            <div class="sgc-card__body">
                                <div class="sgc-chart" t-ref="stateChart"/>
                            </div>
                        </div>
                    </div>

                    <!-- Row 5: Status strip -->
                    <div class="sgc-status-strip">
                        <div class="sgc-status-card">
                            <div class="sgc-status-card__title">Property Status</div>
                            <div class="sgc-status-card__pills">
                                <div class="sgc-pill sgc-pill--green" t-on-click="() => this.viewProperties('available')">
                                    <span class="sgc-pill__dot"/><span class="sgc-pill__label">Available</span>
                                    <span class="sgc-pill__value"><t t-esc="state.avail_property"/></span>
                                </div>
                                <div class="sgc-pill sgc-pill--blue" t-on-click="() => this.viewProperties('rented')">
                                    <span class="sgc-pill__dot"/><span class="sgc-pill__label">Rented</span>
                                    <span class="sgc-pill__value"><t t-esc="state.rented_property"/></span>
                                </div>
                                <div class="sgc-pill sgc-pill--red" t-on-click="() => this.viewProperties('sold')">
                                    <span class="sgc-pill__dot"/><span class="sgc-pill__label">Sold</span>
                                    <span class="sgc-pill__value"><t t-esc="state.sold_property"/></span>
                                </div>
                                <div class="sgc-pill sgc-pill--amber" t-on-click="() => this.viewProperties('maintenance')">
                                    <span class="sgc-pill__dot"/><span class="sgc-pill__label">Maintenance</span>
                                    <span class="sgc-pill__value"><t t-esc="state.maintenance_property"/></span>
                                </div>
                            </div>
                        </div>

                        <div class="sgc-status-card">
                            <div class="sgc-status-card__title">Sales Pipeline</div>
                            <div class="sgc-status-card__bars">
                                <div class="sgc-bar-row">
                                    <span class="sgc-bar-row__label">Booked</span>
                                    <span class="sgc-bar-row__count"><t t-esc="state.booked"/></span>
                                    <div class="sgc-bar-row__track">
                                        <div class="sgc-bar-row__fill sgc-bar-row__fill--wo"
                                             t-attf-style="width: #{Math.min(100, ((state.booked || 0) / Math.max(1, state.total_property)) * 100)}%;"/>
                                    </div>
                                </div>
                                <div class="sgc-bar-row">
                                    <span class="sgc-bar-row__label">Contracts Signed</span>
                                    <span class="sgc-bar-row__count"><t t-esc="state.sale_sold"/></span>
                                    <div class="sgc-bar-row__track">
                                        <div class="sgc-bar-row__fill sgc-bar-row__fill--wo"
                                             t-attf-style="width: #{Math.min(100, ((state.sale_sold || 0) / Math.max(1, state.total_property)) * 100)}%;"/>
                                    </div>
                                </div>
                                <div class="sgc-bar-row">
                                    <span class="sgc-bar-row__label">Properties Sold</span>
                                    <span class="sgc-bar-row__count"><t t-esc="state.sold_property"/></span>
                                    <div class="sgc-bar-row__track">
                                        <div class="sgc-bar-row__fill sgc-bar-row__fill--wo"
                                             t-attf-style="width: #{Math.min(100, ((state.sold_property || 0) / Math.max(1, state.total_property)) * 100)}%;"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="sgc-status-card">
                            <div class="sgc-status-card__title">Pending Invoices</div>
                            <div class="sgc-status-card__bars">
                                <div class="sgc-bar-row">
                                    <span class="sgc-bar-row__label">Rent Unpaid</span>
                                    <span class="sgc-bar-row__count"><t t-esc="state.pending_invoice"/></span>
                                    <div class="sgc-bar-row__track">
                                        <div class="sgc-bar-row__fill sgc-bar-row__fill--mrr"
                                             t-attf-style="width: #{Math.min(100, (state.pending_invoice || 0) * 5)}%;"/>
                                    </div>
                                </div>
                                <div class="sgc-bar-row">
                                    <span class="sgc-bar-row__label">Sale Unpaid</span>
                                    <span class="sgc-bar-row__count"><t t-esc="state.pending_invoice_sale"/></span>
                                    <div class="sgc-bar-row__track">
                                        <div class="sgc-bar-row__fill sgc-bar-row__fill--mrr"
                                             t-attf-style="width: #{Math.min(100, (state.pending_invoice_sale || 0) * 5)}%;"/>
                                    </div>
                                </div>
                                <div class="sgc-bar-row">
                                    <span class="sgc-bar-row__label">Running Contracts</span>
                                    <span class="sgc-bar-row__count"><t t-esc="state.running_contract"/></span>
                                    <div class="sgc-bar-row__track">
                                        <div class="sgc-bar-row__fill sgc-bar-row__fill--wo"
                                             t-attf-style="width: #{Math.min(100, (state.running_contract || 0) * 5)}%;"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Row 6: UAE Properties Map -->
                    <div class="sgc-map sgc-map--full-bleed">
                        <div class="sgc-map__header">
                            <div>
                                <div class="sgc-map__title">UAE Properties Map</div>
                                <div class="sgc-map__subtitle">Portfolio Distribution Across Emirates</div>
                            </div>
                        </div>
                        <div class="sgc-map__viewport" t-ref="mapViewport"/>
                        <div class="sgc-map__legend">
                            <div class="sgc-map__legend-title">STATUS LEGEND</div>
                            <div class="sgc-map__legend-item">
                                <span class="sgc-map__legend-dot" style="background:#22c55e;"/>AVAILABLE
                            </div>
                            <div class="sgc-map__legend-item">
                                <span class="sgc-map__legend-dot" style="background:#60a5fa;"/>RENTED
                            </div>
                            <div class="sgc-map__legend-item">
                                <span class="sgc-map__legend-dot" style="background:#ef4444;"/>SOLD
                            </div>
                            <div class="sgc-map__legend-item">
                                <span class="sgc-map__legend-dot" style="background:#f59e0b;"/>MAINTENANCE
                            </div>
                        </div>
                    </div>

                </div>
            </main>
        </div>
    </t>

</templates>
