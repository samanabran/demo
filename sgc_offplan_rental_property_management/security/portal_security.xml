<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="portal_rule_rent_contract_tenant" model="ir.rule">
        <field name="name">Portal: Own Lease as Tenant</field>
        <field name="model_id" ref="model_rent_contract"/>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="domain_force">[('tenant_id.user_ids', 'in', [user.id])]</field>
    </record>
    <record id="portal_rule_rent_contract_landlord" model="ir.rule">
        <field name="name">Portal: Own Lease as Landlord</field>
        <field name="model_id" ref="model_rent_contract"/>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="domain_force">[('landlord_id.user_ids', 'in', [user.id])]</field>
    </record>
    <record id="portal_rule_tenancy_details_tenant" model="ir.rule">
        <field name="name">Portal: Own Lease as Tenant</field>
        <field name="model_id" ref="model_tenancy_details"/>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="domain_force">[('tenant_id.user_ids', 'in', [user.id])]</field>
    </record>
    <record id="portal_rule_tenancy_details_landlord" model="ir.rule">
        <field name="name">Portal: Own Lease as Landlord</field>
        <field name="model_id" ref="model_tenancy_details"/>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="domain_force">[('landlord_id.user_ids', 'in', [user.id])]</field>
    </record>
    <record id="portal_rule_sale_contract" model="ir.rule">
        <field name="name">Portal: Own Purchase</field>
        <field name="model_id" ref="model_sale_contract"/>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="domain_force">[('buyer_id.user_ids', 'in', [user.id])]</field>
    </record>
    <record id="portal_rule_property_vendor" model="ir.rule">
        <field name="name">Portal: Own Booking</field>
        <field name="model_id" ref="model_property_vendor"/>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="domain_force">[('customer_id.user_ids', 'in', [user.id])]</field>
    </record>
    <record id="portal_rule_maintenance_request" model="ir.rule">
        <field name="name">Portal: Own Maintenance</field>
        <field name="model_id" ref="maintenance.model_maintenance_request"/>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="domain_force">['|', ('tenant_id.user_ids', 'in', [user.id]), ('landlord_id.user_ids', 'in', [user.id])]</field>
    </record>
    <record id="portal_rule_account_move" model="ir.rule">
        <field name="name">Portal: Own Invoices</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="domain_force">[('partner_id.user_ids', 'in', [user.id])]</field>
    </record>
    <record id="portal_rule_property_documents" model="ir.rule">
        <field name="name">Portal: Visible Documents Only</field>
        <field name="model_id" ref="model_property_documents"/>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="domain_force">[('portal_visible', '=', True)]</field>
    </record>
</odoo>
