<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="payment_schedule_report_template">
        <t t-call="web.html_container">
          <t t-foreach="docs" t-as="o">
            <t t-call="web.external_layout">
            <div class="page">
                <div class="row mb-4">
                    <div class="col-12 text-center">
                        <h1>Payment Schedule</h1>
                        <p><strong>Schedule:</strong> <span t-esc="o.name"/></p>
                        <p><strong>Type:</strong> <span t-esc="dict(o._fields['schedule_type'].selection).get(o.schedule_type, o.schedule_type)"/></p>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-12">
                        <table class="table table-bordered" style="page-break-inside:avoid;">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Description</th>
                                    <th>Percentage</th>
                                    <th>Days After Contract</th>
                                    <th>Frequency</th>
                                    <th>Installments</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="o.schedule_line_ids" t-as="line">
                                    <td t-esc="line.sequence"/>
                                    <td style="word-break:break-word;" t-esc="line.name"/>
                                    <td t-esc="str(line.percentage) + ' %'"/>
                                    <td t-esc="line.days_after"/>
                                    <td t-esc="dict(line._fields['installment_frequency'].selection).get(line.installment_frequency, line.installment_frequency)"/>
                                    <td t-esc="line.number_of_installments"/>
                                </tr>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <th colspan="2">Total</th>
                                    <th t-esc="str(o.total_percentage) + ' %'"/>
                                    <th colspan="3"/>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>

                <p class="mt-5 text-muted small text-center">
                    This is a computer-generated payment schedule.
                </p>
            </div>
            </t>
          </t>
        </t>
    </template>
</odoo>
