<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="sale_contract_installment_plan_template">
        <t t-call="web.html_container">
          <t t-foreach="docs" t-as="o">
            <t t-set="total_paid" t-value="o.total_paid"/>
            <t t-set="outstanding" t-value="(o.sale_price or 0.0) - total_paid"/>
            <t t-set="pct_complete" t-value="round((total_paid / o.sale_price) * 100, 1) if o.sale_price else 0.0"/>
            <t t-call="web.external_layout">
            <div class="page">
                <style>
                    .ip-summary { border-collapse: collapse; width: 100%; margin-bottom: 18px; }
                    .ip-summary td { padding: 10px 14px; border: 1px solid #dcdcdc; vertical-align: top; }
                    .ip-summary .ip-label { font-size: 10px; text-transform: uppercase; letter-spacing: 1px; color: #6b6b6b; margin-bottom: 3px; }
                    .ip-summary .ip-value { font-size: 14px; font-weight: 700; color: #1a1a2e; }
                    .ip-table { width: 100%; border-collapse: collapse; }
                    .ip-table th { background: #0a1628; color: #fff; padding: 8px 10px; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; text-align: left; }
                    .ip-table td { padding: 8px 10px; border-bottom: 1px solid #e5e5e5; font-size: 12px; }
                    .ip-table tr:nth-child(even) td { background: #f7f8fa; }
                    .ip-badge { display: inline-block; padding: 2px 10px; border-radius: 10px; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
                    .ip-badge-paid { background: #d7f2e0; color: #157347; }
                    .ip-badge-pending { background: #fff3cd; color: #997404; }
                    .ip-badge-overdue { background: #f8d7da; color: #b02a37; }
                    .ip-progress-outer { background: #e5e5e5; border-radius: 6px; height: 10px; width: 100%; overflow: hidden; }
                    .ip-progress-inner { background: #c9a961; height: 10px; }
                </style>

                <div class="row mb-3">
                    <div class="col-12 text-center">
                        <h1 style="color:#0a1628;">Installment Payment Plan</h1>
                        <p class="text-muted mb-0">Contract <span t-esc="o.name"/></p>
                    </div>
                </div>

                <table class="ip-summary">
                    <tr>
                        <td style="width:33%;">
                            <div class="ip-label">Property</div>
                            <div class="ip-value" t-esc="o.property_id.name or '-'"/>
                        </td>
                        <td style="width:33%;">
                            <div class="ip-label">Buyer</div>
                            <div class="ip-value" t-esc="o.buyer_id.name or '-'"/>
                        </td>
                        <td style="width:34%;">
                            <div class="ip-label">Contract Date</div>
                            <div class="ip-value" t-esc="o.contract_date or '-'"/>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <div class="ip-label">Total Contract Value</div>
                            <div class="ip-value"><span t-esc="o.sale_price" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></div>
                        </td>
                        <td>
                            <div class="ip-label">Total Paid</div>
                            <div class="ip-value" style="color:#157347;"><span t-esc="total_paid" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></div>
                        </td>
                        <td>
                            <div class="ip-label">Outstanding Balance</div>
                            <div class="ip-value" style="color:#b02a37;"><span t-esc="outstanding" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></div>
                        </td>
                    </tr>
                    <tr>
                        <td colspan="3">
                            <div class="ip-label">Payment Progress — <span t-esc="pct_complete"/>% complete</div>
                            <div class="ip-progress-outer">
                                <div class="ip-progress-inner" t-attf-style="width: #{min(pct_complete, 100)}%;"/>
                            </div>
                        </td>
                    </tr>
                </table>

                <table class="ip-table" style="page-break-inside:avoid;">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Description</th>
                            <th>Due Date</th>
                            <th>%</th>
                            <th>Amount</th>
                            <th>Status</th>
                            <th>Payment Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="o.installment_ids.sorted(key=lambda l: (l.sequence, l.due_date or ''))" t-as="line">
                            <td t-esc="line.sequence"/>
                            <td style="word-break:break-word;" t-esc="line.name"/>
                            <td t-esc="line.due_date or '-'"/>
                            <td t-esc="('%.2f' % line.percentage) + '%' if line.percentage else '-'"/>
                            <td><span t-esc="line.amount" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td>
                            <td>
                                <span t-if="line.state == 'paid'" class="ip-badge ip-badge-paid">Paid</span>
                                <span t-elif="line.state == 'overdue'" class="ip-badge ip-badge-overdue">Overdue</span>
                                <span t-else="" class="ip-badge ip-badge-pending">Pending</span>
                            </td>
                            <td t-esc="line.payment_date or '-'"/>
                        </tr>
                        <tr t-if="not o.installment_ids">
                            <td colspan="7" class="text-center text-muted">No installments have been scheduled for this contract.</td>
                        </tr>
                    </tbody>
                    <tfoot t-if="o.installment_ids">
                        <tr>
                            <th colspan="4">Total</th>
                            <th><span t-esc="sum(o.installment_ids.mapped('amount'))" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></th>
                            <th colspan="2"/>
                        </tr>
                    </tfoot>
                </table>

                <p class="mt-5 text-muted small text-center">
                    This is a computer-generated installment payment plan. Figures reflect the system as of the print date.
                </p>
            </div>
            </t>
          </t>
        </t>
    </template>

    <record id="action_report_sale_contract_installment_plan" model="ir.actions.report">
        <field name="name">Installment Payment Plan</field>
        <field name="model">sale.contract</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sgc_offplan_rental_property_management.sale_contract_installment_plan_template</field>
        <field name="report_file">sgc_offplan_rental_property_management.sale_contract_installment_plan_template</field>
        <field name="binding_model_id" ref="model_sale_contract"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Installment Plan - %s' % (object.name)</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>
</odoo>
