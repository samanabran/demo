<?xml version="1.0" encoding="utf-8"?>
<!--
    Copyright (C) 2026 SGC TECH AI
    Sales & Purchase Agreement (SPA) — professional legal contract template.

    Bound both to:
      - property.vendor (booking record with sale_contract_id link)
      - sale.contract    (direct binding via the contract form Print menu)

    Layout: portrait A4, branded letterhead, two-column parties + property card,
    numbered sections, monetary tables, and signature blocks. Page-break safe via
    <div class="keep-together"> wrappers so no section is orphaned across pages.

    Render-time guards:
      - missing docs (deleted record): stub page so report never 500s
      - missing related records: every many2one access is `t-if`-guarded
-->
<odoo>

    <!-- ═══ Stylesheet (scoped to this template; injected via t-call) ═══ -->
    <template id="sales_purchase_agreement_styles" name="SPA Styles">
        <style>
            /* ── Page setup ────────────────────────────────────────── */
            .o_spa_page {
                font-family: "Helvetica", "Arial", sans-serif;
                font-size: 10pt;
                line-height: 1.45;
                color: #1f2937;
            }
            .o_spa_page *,
            .o_spa_page *:before,
            .o_spa_page *:after { box-sizing: border-box; }

            /* ── Letterhead ────────────────────────────────────────── */
            .o_spa_letterhead {
                display: flex;
                align-items: center;
                justify-content: space-between;
                border-bottom: 3px solid #1f2937;
                padding: 0 0 10pt 0;
                margin-bottom: 18pt;
            }
            .o_spa_letterhead .brand { display: flex; flex-direction: column; }
            .o_spa_letterhead .brand-name {
                font-size: 20pt;
                font-weight: 700;
                color: #0f172a;
                letter-spacing: 0.5pt;
            }
            .o_spa_letterhead .brand-tag {
                font-size: 8.5pt;
                color: #475569;
                margin-top: 2pt;
            }
            .o_spa_letterhead .meta {
                text-align: right;
                font-size: 8.5pt;
                color: #475569;
                line-height: 1.4;
            }
            .o_spa_letterhead .meta strong { color: #1f2937; }

            /* ── Title bar ─────────────────────────────────────────── */
            .o_spa_title {
                text-align: center;
                background: #0f172a;
                color: #ffffff;
                padding: 10pt 14pt;
                font-size: 14pt;
                font-weight: 700;
                letter-spacing: 1pt;
                margin: 0 0 16pt 0;
            }
            .o_spa_agreement_meta {
                display: flex;
                justify-content: space-between;
                margin-bottom: 18pt;
                padding: 8pt 14pt;
                background: #f1f5f9;
                border-left: 4px solid #0f172a;
            }
            .o_spa_agreement_meta span { font-size: 10pt; }
            .o_spa_agreement_meta strong { color: #0f172a; }

            /* ── Section headings ──────────────────────────────────── */
            .o_spa_section {
                page-break-inside: avoid;
                margin: 0 0 14pt 0;
            }
            .o_spa_section h3 {
                font-size: 11pt;
                font-weight: 700;
                color: #ffffff;
                background: #1e3a8a;
                padding: 6pt 10pt;
                margin: 0 0 8pt 0;
                border-radius: 2pt;
            }
            .o_spa_section h3 .num {
                display: inline-block;
                width: 18pt;
                color: #bfdbfe;
            }

            /* ── Two-column definition list (label : value) ──────── */
            .o_spa_dl {
                width: 100%;
                border-collapse: collapse;
            }
            .o_spa_dl td {
                vertical-align: top;
                padding: 5pt 8pt;
                font-size: 9.5pt;
            }
            .o_spa_dl td.label {
                width: 32%;
                font-weight: 600;
                color: #475569;
                background: #f8fafc;
                border-bottom: 1px solid #e2e8f0;
            }
            .o_spa_dl td.value {
                border-bottom: 1px solid #e2e8f0;
                color: #0f172a;
            }
            .o_spa_dl tr:last-child td { border-bottom: none; }

            /* ── Two-card parties layout ──────────────────────────── */
            .o_spa_cards {
                display: flex;
                gap: 10pt;
                margin-bottom: 14pt;
            }
            .o_spa_card {
                flex: 1;
                border: 1px solid #e2e8f0;
                border-top: 3px solid #1e3a8a;
                padding: 10pt 12pt;
                border-radius: 2pt;
            }
            .o_spa_card h4 {
                margin: 0 0 6pt 0;
                font-size: 9pt;
                font-weight: 700;
                letter-spacing: 1pt;
                color: #1e3a8a;
                text-transform: uppercase;
            }
            .o_spa_card .role {
                font-size: 11pt;
                font-weight: 700;
                color: #0f172a;
                margin-bottom: 4pt;
            }
            .o_spa_card .meta-line {
                font-size: 8.5pt;
                color: #475569;
                margin-bottom: 1pt;
            }

            /* ── Tables (money, installments) ──────────────────────── */
            .o_spa_table {
                width: 100%;
                border-collapse: collapse;
                font-size: 9pt;
            }
            .o_spa_table thead th {
                background: #1e3a8a;
                color: #ffffff;
                text-align: left;
                padding: 6pt 8pt;
                font-weight: 600;
                font-size: 8.5pt;
                letter-spacing: 0.5pt;
                text-transform: uppercase;
            }
            .o_spa_table tbody td {
                padding: 5pt 8pt;
                border-bottom: 1px solid #e2e8f0;
                color: #1f2937;
            }
            .o_spa_table tbody tr:nth-child(even) td { background: #f8fafc; }
            .o_spa_table tfoot td {
                padding: 6pt 8pt;
                background: #e0e7ff;
                font-weight: 700;
                color: #0f172a;
                border-top: 2px solid #1e3a8a;
            }
            .o_spa_table .text-right { text-align: right; }
            .o_spa_table .text-center { text-align: center; }

            /* ── Body copy / clauses ──────────────────────────────── */
            .o_spa_clause {
                font-size: 9.5pt;
                line-height: 1.55;
                text-align: justify;
                margin: 0 0 10pt 0;
                color: #1f2937;
            }
            .o_spa_clause strong { color: #0f172a; }

            /* ── Signature blocks ──────────────────────────────────── */
            .o_spa_signatures {
                display: flex;
                gap: 24pt;
                margin-top: 28pt;
                page-break-inside: avoid;
            }
            .o_spa_signature {
                flex: 1;
                border-top: 1px solid #1f2937;
                padding-top: 6pt;
                text-align: center;
            }
            .o_spa_signature .party {
                font-size: 9pt;
                font-weight: 700;
                color: #0f172a;
                letter-spacing: 0.5pt;
                text-transform: uppercase;
            }
            .o_spa_signature .name {
                font-size: 10pt;
                color: #1f2937;
                margin-top: 4pt;
                min-height: 30pt;
            }
            .o_spa_signature .date {
                font-size: 8.5pt;
                color: #64748b;
                margin-top: 18pt;
            }

            /* ── Footer note ──────────────────────────────────────── */
            .o_spa_footnote {
                margin-top: 16pt;
                font-size: 8pt;
                color: #94a3b8;
                text-align: center;
                border-top: 1px solid #e2e8f0;
                padding-top: 6pt;
            }

            /* ── Print: prevent orphan headings + table rows ───────── */
            @page { margin: 14mm; }
            h3, .o_spa_agreement_meta, .o_spa_card,
            .o_spa_signatures { page-break-after: avoid; }
            .o_spa_section, .o_spa_table tr { page-break-inside: avoid; }
        </style>
    </template>

    <!-- ═══ Template body ═══ -->
    <template id="sales_purchase_agreement_template">
        <t t-call="web.html_container">
            <t t-call="sgc_offplan_rental_property_management.sales_purchase_agreement_styles"/>
            <t t-foreach="docs" t-as="o">
            <!-- Guard against stale docids (a vendor/contract may have been deleted
                 after the report was first invoked). Without this guard, accessing
                 `o._name` raises MissingError and the user gets a 500. -->
            <t t-if="o and o.exists() and o.id">
            <t t-set="is_direct_contract" t-value="o._name == 'sale.contract'"/>
            <t t-set="contract" t-value="o if is_direct_contract else o.sale_contract_id"/>
            <t t-set="seller_partner" t-value="o.seller_id if is_direct_contract else o.vendor_id"/>
            <t t-set="buyer_partner" t-value="o.buyer_id if is_direct_contract else o.customer_id"/>
            <t t-set="agreement_ref" t-value="o.name if is_direct_contract else (o.sold_seq or o.name)"/>
            <t t-set="agreement_date" t-value="o.contract_date if is_direct_contract else (o.date or o.contract_date)"/>

            <div class="page o_spa_page">

                <!-- ── 1. Letterhead ────────────────────────────────── -->
                <div class="o_spa_letterhead">
                    <div class="brand">
                        <div class="brand-name">SGC TECH AI</div>
                        <div class="brand-tag">Real Estate · Property Management Suite</div>
                    </div>
                    <div class="meta">
                        <div><strong>United Arab Emirates</strong></div>
                        <div>Dubai · Abu Dhabi · Sharjah</div>
                        <div>support@sgctech.ai</div>
                    </div>
                </div>

                <!-- ── 2. Title ─────────────────────────────────────── -->
                <div class="o_spa_title">SALES &amp; PURCHASE AGREEMENT</div>

                <!-- ── 3. Agreement meta strip ─────────────────────── -->
                <div class="o_spa_agreement_meta">
                    <span><strong>Agreement No:</strong>
                        <t t-esc="agreement_ref or '—'"/>
                    </span>
                    <span><strong>Date:</strong>
                        <t t-esc="agreement_date and agreement_date.strftime('%d %b %Y') or '—'"/>
                    </span>
                </div>

                <!-- ── 4. Parties (cards) ────────────────────────────── -->
                <div class="o_spa_section o_spa_cards" t-if="seller_partner or buyer_partner">
                    <div class="o_spa_card" t-if="seller_partner">
                        <h4>Seller</h4>
                        <div class="role">
                            <t t-esc="seller_partner.name or '—'"/>
                        </div>
                        <div class="meta-line" t-if="seller_partner.vat">
                            <strong>TRN:</strong> <t t-esc="seller_partner.vat"/>
                        </div>
                        <div class="meta-line" t-if="seller_partner.phone">
                            <strong>Tel:</strong> <t t-esc="seller_partner.phone"/>
                        </div>
                        <div class="meta-line" t-if="seller_partner.email">
                            <strong>Email:</strong> <t t-esc="seller_partner.email"/>
                        </div>
                    </div>
                    <div class="o_spa_card" t-if="buyer_partner">
                        <h4>Buyer</h4>
                        <div class="role">
                            <t t-esc="buyer_partner.name or '—'"/>
                        </div>
                        <div class="meta-line" t-if="buyer_partner.vat">
                            <strong>TRN:</strong> <t t-esc="buyer_partner.vat"/>
                        </div>
                        <div class="meta-line" t-if="buyer_partner.phone">
                            <strong>Tel:</strong> <t t-esc="buyer_partner.phone"/>
                        </div>
                        <div class="meta-line" t-if="buyer_partner.email">
                            <strong>Email:</strong> <t t-esc="buyer_partner.email"/>
                        </div>
                    </div>
                </div>

                <!-- ── 5. Property ────────────────────────────────────── -->
                <div class="o_spa_section" t-if="o.property_id">
                    <h3><span class="num">1.</span>Property</h3>
                    <table class="o_spa_dl">
                        <tr>
                            <td class="label">Property</td>
                            <td class="value">
                                <strong t-esc="o.property_id.name or '—'"/>
                            </td>
                        </tr>
                        <tr t-if="o.property_id.property_type">
                            <td class="label">Type</td>
                            <td class="value" t-esc="o.property_id.property_type"/>
                        </tr>
                        <tr t-if="o.property_id.city">
                            <td class="label">City</td>
                            <td class="value" t-esc="o.property_id.city"/>
                        </tr>
                        <tr t-if="o.property_id.area">
                            <td class="label">Area</td>
                            <td class="value">
                                <span t-esc="'%s sqft' % o.property_id.area"/>
                            </td>
                        </tr>
                        <tr t-if="o.property_id.title_deed_number">
                            <td class="label">Title Deed No.</td>
                            <td class="value" t-esc="o.property_id.title_deed_number"/>
                        </tr>
                    </table>
                </div>

                <!-- ── 6. Commission Distribution ──────────────────────── -->
                <div class="o_spa_section" t-if="o.commission_line_ids or contract.commission_line_ids">
                    <h3><span class="num">2.</span>Commission Distribution</h3>
                    <table class="o_spa_table">
                        <thead>
                            <tr>
                                <th>Category</th>
                                <th>Role</th>
                                <th>Beneficiary</th>
                                <th class="text-right">Rate</th>
                                <th class="text-right">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="display_lines" t-value="o.commission_line_ids or contract.commission_line_ids"/>
                            <t t-foreach="display_lines" t-as="line">
                                <tr>
                                    <td t-esc="dict(line._fields['category'].selection).get(line.category, line.category)"/>
                                    <td t-esc="line.get_role_label()"/>
                                    <td t-esc="line.partner_id.name if line.partner_id else '—'"/>
                                    <td class="text-right">
                                        <t t-if="line.commission_percentage and line.commission_percentage &gt; 0">
                                            <span t-esc="str(line.commission_percentage) + '%'"/>
                                        </t>
                                        <t t-else="">—</t>
                                    </td>
                                    <td class="text-right">
                                        <span t-esc="line.commission_amount"
                                              t-options="{'widget': 'monetary', 'display_currency': o.currency_id or o.company_id.currency_id}"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="4" class="text-right">Total Commission</td>
                                <td class="text-right">
                                    <t t-if="not o.commission_line_ids and contract.commission_line_ids">
                                        <span t-esc="contract.commission_total_amount"
                                              t-options="{'widget': 'monetary', 'display_currency': o.currency_id or o.company_id.currency_id}"/>
                                    </t>
                                    <t t-else="">
                                        <span t-esc="o.total_commission or 0.0"
                                              t-options="{'widget': 'monetary', 'display_currency': o.currency_id or o.company_id.currency_id}"/>
                                    </t>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <!-- ── 7. Purchase Price &amp; Payment Terms ─────────────── -->
                <div class="o_spa_section">
                    <h3><span class="num">3.</span>Purchase Price &amp; Payment Terms</h3>
                    <table class="o_spa_dl">
                        <tr>
                            <td class="label">Purchase Price</td>
                            <td class="value">
                                <strong t-esc="o.sale_price"
                                       t-options="{'widget': 'monetary', 'display_currency': o.currency_id or o.company_id.currency_id}"/>
                            </td>
                        </tr>
                        <tr t-if="o.property_id.dld_fee or o.property_id.dld_fee_percentage">
                            <td class="label">DLD Registration Fee</td>
                            <td class="value">
                                <t t-if="o.property_id.dld_fee">
                                    <span t-esc="o.property_id.dld_fee"
                                          t-options="{'widget': 'monetary', 'display_currency': o.currency_id or o.company_id.currency_id}"/>
                                </t>
                                <t t-else="">
                                    <span t-esc="'%s%% of purchase price' % o.property_id.dld_fee_percentage"/>
                                </t>
                            </td>
                        </tr>
                    </table>
                </div>

                <!-- ── 8. Title Deed &amp; Oqood (DLD) ─────────────────────── -->
                <div class="o_spa_section">
                    <h3><span class="num">4.</span>Title Deed &amp; Oqood Registration (DLD)</h3>
                    <p class="o_spa_clause">
                        The Property is held under Title Deed No.
                        <strong t-esc="o.property_id.title_deed_number or '—'"/>
                        issued by the Dubai Land Department (DLD). Upon completion of this Agreement the Parties shall procure
                        registration of the transfer with the DLD through Trakhees/Ejar-certified registration channels and shall
                        pay the applicable DLD registration fee (currently 4% of the Purchase Price for the primary market, or as
                        otherwise prescribed by DLD from time to time), together with the AED 580 DLD issuance fee and AED 2,000
                        Trustee fee, in the proportions required by RERA/DLD. Where the Property is an off-plan unit, this
                        Agreement shall be converted to Oqood registration and the corresponding Oqood fee shall be borne by the
                        Buyer.
                    </p>
                </div>

                <!-- ── 9. Handover ────────────────────────────────────────── -->
                <div class="o_spa_section">
                    <h3><span class="num">5.</span>Handover, Title Transfer &amp; Snagging</h3>
                    <p class="o_spa_clause">
                        The Seller shall handover physical possession of the Property to the Buyer on
                        <strong t-esc="contract and contract.handover_date and contract.handover_date.strftime('%d %b %Y') or 'the date agreed in Schedule A'"/>,
                        free of encumbrances, together with all original title instruments, NOCs, and the transfer forms required
                        for registration. A joint Pre-Handover Inspection shall be carried out no later than 14 (fourteen) days
                        before the Handover Date. Any defect identified during such inspection shall form the Snagging List; the
                        Seller shall rectify all snagging items within 60 (sixty) days of Handover at no cost to the Buyer. Title
                        Transfer shall be completed at DLD no later than 30 (thirty) days after the Handover Date, and the
                        Seller shall execute all documents necessary thereto.
                    </p>
                </div>

                <!-- ── 10. Payment Schedule (only if installments exist) ────── -->
                <t t-set="spa_installments" t-value="contract.installment_ids if contract else o.env['sale.contract.installment']"/>
                <t t-set="spa_total_amount" t-value="0"/>
                <t t-set="spa_purchase_price" t-value="contract.sale_price if contract else 0"/>
                <div class="o_spa_section" t-if="spa_installments">
                    <h3><span class="num">6.</span>Payment Schedule Summary</h3>
                    <table class="o_spa_table">
                        <thead>
                            <tr>
                                <th class="text-center" style="width:6%;">#</th>
                                <th style="width:46%;">Milestone</th>
                                <th class="text-right" style="width:10%;">%</th>
                                <th class="text-right" style="width:20%;">Amount (AED)</th>
                                <th class="text-center" style="width:18%;">Due Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="spa_installments" t-as="line">
                                <tr>
                                    <td class="text-center" t-esc="line.sequence"/>
                                    <td t-esc="line.name"/>
                                    <td class="text-right">
                                        <span t-if="line.percentage and line.percentage &gt; 0"
                                              t-out="str(line.percentage) + '%'"/>
                                        <span t-if="not line.percentage or line.percentage == 0">—</span>
                                    </td>
                                    <td class="text-right">
                                        <span t-esc="line.amount"
                                              t-options="{'widget': 'monetary', 'display_currency': o.currency_id or o.company_id.currency_id}"/>
                                    </td>
                                    <td class="text-center" t-esc="line.due_date and line.due_date.strftime('%d %b %Y') or '—'"/>
                                </tr>
                                <t t-set="spa_total_amount" t-value="spa_total_amount + line.amount"/>
                            </t>
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="3" class="text-right">Total Scheduled</td>
                                <td class="text-right">
                                    <span t-esc="spa_total_amount"
                                          t-options="{'widget': 'monetary', 'display_currency': o.currency_id or o.company_id.currency_id}"/>
                                </td>
                                <td></td>
                            </tr>
                            <tr>
                                <td colspan="3" class="text-right">Purchase Price (Reference)</td>
                                <td class="text-right">
                                    <span t-esc="spa_purchase_price"
                                          t-options="{'widget': 'monetary', 'display_currency': o.currency_id or o.company_id.currency_id}"/>
                                </td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                    <p class="o_spa_clause" style="margin-top:8pt;">
                        <em>Example interpretation:</em>
                        a 20% down-payment followed by up to <strong t-esc="len(spa_installments)-1"/> monthly
                        instalments totalling
                        <strong t-esc="spa_total_amount"
                                t-options="{'widget': 'monetary', 'display_currency': o.currency_id or o.company_id.currency_id}"/>,
                        as detailed in the table above. This Schedule is illustrative of the Buyer's payment obligations under
                        this Agreement and forms an integral part thereof.
                    </p>
                </div>

                <!-- ── 11. AED Denomination ───────────────────────────────── -->
                <div class="o_spa_section">
                    <h3><span class="num">7.</span>AED Denomination &amp; Payment Mechanism</h3>
                    <p class="o_spa_clause">
                        All amounts under this Agreement are denominated in UAE Dirhams (AED). Payments shall be made by
                        manager's cheque or wire transfer to the Seller's nominated UAE-resident bank account. Any
                        cross-border transfer shall be processed through an UAE-licensed exchange and shall comply with the
                        anti-money laundering regulations issued by the Central Bank of the UAE and the Financial Action
                        Task Force (FATF).
                    </p>
                </div>

                <!-- ── 12. Brokerage Disclosure ─────────────────────────────── -->
                <div class="o_spa_section" t-if="o.broker_id">
                    <h3><span class="num">8.</span>Brokerage Disclosure</h3>
                    <p class="o_spa_clause">
                        The Parties acknowledge that this transaction was facilitated by
                        <strong t-esc="o.broker_id.name"/>. Brokerage commission, if any, shall be paid outside the closing
                        balance pursuant to the standalone Brokerage Agreement and shall be borne by the Seller as agreed
                        between Seller and Broker.
                    </p>
                </div>

                <!-- ── 13. Service Charges ────────────────────────────────────── -->
                <div class="o_spa_section">
                    <h3><span class="num">9.</span>Handover Payment, Service Charges &amp; Title Transfer</h3>
                    <p class="o_spa_clause">
                        The Buyer undertakes to pay all annual service charges (chiller fees, district cooling, building
                        management, sinking-fund contributions) to the owner-association/community-management company as
                        and when due from the Handover Date onward. Service charges accrued before Handover remain the
                        obligation of the Seller. Pre-handover unpaid developer service charges, if any, are to be
                        settled by the Seller from the final tranche of the Purchase Price.
                    </p>
                </div>

                <!-- ── 14. Mortgagee / NOC ─────────────────────────────────────── -->
                <div class="o_spa_section">
                    <h3><span class="num">10.</span>Mortgagee / NOC</h3>
                    <p class="o_spa_clause">
                        If the Seller's title is encumbered by any prior mortgage or charge, the Seller shall obtain and
                        deliver to the Buyer a No-Objection Certificate (NOC) from the existing mortgagee prior to or at
                        DLD registration. All pre-closing mortgage cancellation fees, if any, shall be the Seller's
                        cost. Until registration of the Buyer as registered owner, the Buyer shall not be liable for
                        any mortgage instalment, and the Seller remains responsible for any default.
                    </p>
                </div>

                <!-- ── 15. AML / KYC ────────────────────────────────────────────── -->
                <div class="o_spa_section">
                    <h3><span class="num">11.</span>Buyer's Representations &amp; AML/KYC</h3>
                    <p class="o_spa_clause">
                        The Buyer represents that the funds used for this Purchase Price are not proceeds of crime, that
