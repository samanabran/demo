<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── RERA Form A - Tree View ────────────────────────────────── -->
    <record id="rera_form_a_view_tree" model="ir.ui.view">
        <field name="name">rera.form.a.tree</field>
        <field name="model">rera.form.a</field>
        <field name="arch" type="xml">
            <list string="RERA Form A" decoration-danger="state == 'expired'" decoration-muted="state == 'cancelled'" decoration-success="state == 'active'" decoration-info="state == 'signed'">
                <field name="name"/>
                <field name="property_id"/>
                <field name="owner_id"/>
                <field name="state" widget="badge"/>
                <field name="valid_from"/>
                <field name="valid_until"/>
                <field name="permit_status" widget="badge"/>
                <field name="listing_price" widget="monetary"/>
                <field name="currency_id" invisible="1"/>
                <field name="listing_type"/>
            </list>
        </field>
    </record>

    <!-- ─── RERA Form A - Search View ──────────────────────────────── -->
    <record id="rera_form_a_view_search" model="ir.ui.view">
        <field name="name">rera.form.a.search</field>
        <field name="model">rera.form.a</field>
        <field name="arch" type="xml">
            <search string="Search Form A">
                <field name="name"/>
                <field name="property_id"/>
                <field name="owner_id"/>
                <field name="agent_id"/>
                <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="filter_signed" string="Signed" domain="[('state', '=', 'signed')]"/>
                <filter name="filter_active" string="Active" domain="[('state', '=', 'active')]"/>
                <filter name="filter_expired" string="Expired" domain="[('state', '=', 'expired')]"/>
                <filter name="filter_cancelled" string="Cancelled" domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter name="filter_sale" string="For Sale" domain="[('listing_type', '=', 'sale')]"/>
                <filter name="filter_rent" string="For Rent" domain="[('listing_type', '=', 'rent')]"/>
                <filter name="filter_exclusive" string="Exclusive" domain="[('is_exclusive', '=', True)]"/>
                <group>
                    <filter name="groupby_state" string="State" context="{'group_by': 'state'}"/>
                    <filter name="groupby_listing_type" string="Listing Type" context="{'group_by': 'listing_type'}"/>
                    <filter name="groupby_permit_status" string="Permit Status" context="{'group_by': 'permit_status'}"/>
                </group>
                <searchpanel>
                    <field name="state" string="State" select="multi"/>
                    <field name="listing_type" string="Listing Type" select="multi"/>
                    <field name="permit_status" string="Permit Status" select="multi"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <!-- ─── RERA Form A - Form View ────────────────────────────────── -->
    <record id="rera_form_a_form_view" model="ir.ui.view">
        <field name="name">rera.form.a.form</field>
        <field name="model">rera.form.a</field>
        <field name="arch" type="xml">
            <form string="RERA Form A">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,signed,active,expired,cancelled"/>
                    <button name="action_sign" type="object" string="Sign"
                        class="btn-primary"
                        invisible="state != 'draft'"/>
                    <button name="action_activate" type="object" string="Activate"
                        class="btn-success"
                        invisible="state != 'signed'"/>
                    <button name="action_expire" type="object" string="Expire"
                        class="btn-warning"
                        invisible="state not in ('draft', 'signed', 'active')"/>
                    <button name="action_cancel" type="object" string="Cancel"
                        class="btn-outline-danger"
                        invisible="state in ('expired', 'cancelled')"/>
                </header>
                <field name="company_id" invisible="1"/>
                <field name="currency_id" invisible="1"/>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_linked_property"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-building-o">
                            <field name="property_id" widget="statinfo" string="Property"/>
                        </button>
                    </div>
                    <group>
                        <group string="Agreement Details">
                            <field name="name"/>
                            <field name="agreement_date"/>
                            <field name="valid_from"/>
                            <field name="valid_until"/>
                        </group>
                        <group string="Property Info">
                            <field name="property_id" options="{'no_create': True}"/>
                            <field name="listing_type"/>
                            <field name="listing_price" widget="monetary"/>
                            <field name="is_exclusive"/>
                        </group>
                    </group>
                    <group>
                        <group string="Parties">
                            <field name="owner_id" options="{'no_create': True}"/>
                            <field name="agent_id" options="{'no_create': True}"/>
                            <field name="broker_id" options="{'no_create': True}"/>
                            <field name="buyer_id" options="{'no_create': True}"/>
                        </group>
                        <group string="Commission">
                            <field name="commission_type"/>
                            <field name="commission_amount"/>
                            <field name="commission_total" widget="monetary"/>
                        </group>
                    </group>
                    <group>
                        <group string="DLD Permit">
                            <field name="permit_number"/>
                            <field name="dld_permit_number"/>
                            <field name="permit_status" widget="badge"/>
                            <field name="permit_issue_date"/>
                            <field name="permit_expiry_date"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ─── Action: Open RERA Form A list (menu target) ────────────── -->
    <record id="action_rera_form_a" model="ir.actions.act_window">
        <field name="name">RERA Form A</field>
        <field name="res_model">rera.form.a</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first RERA Form A listing agreement
            </p>
            <p>
                RERA Form A is a mandatory listing agreement between the property owner and the
                broker/agency. It must be signed before listing any property for sale or rent.
            </p>
        </field>
    </record>

    <!-- ─── Action: Open Form A from property smart-button ─────────── -->
    <record id="action_property_open_form_a" model="ir.actions.act_window">
        <field name="name">RERA Form A</field>
        <field name="res_model">rera.form.a</field>
        <field name="view_mode">form</field>
        <field name="binding_model_id" ref="model_property_details"/>
        <field name="binding_view_types">form</field>
        <field name="context">{'default_property_id': active_id}</field>
        <field name="help" type="html">
            <p>RERA Form A - Listing Agreement for this property</p>
        </field>
    </record>

</odoo>
