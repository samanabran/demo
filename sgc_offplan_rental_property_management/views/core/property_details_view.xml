<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ─── Tree view with avatar ─────────────────────────────────── -->
    <record id="property_details_view_tree" model="ir.ui.view">
        <field name="name">property.details.tree</field>
        <field name="model">property.details</field>
        <field name="arch" type="xml">
            <list string="Properties" decoration-success="state == 'available'" decoration-warning="state == 'booked'" decoration-muted="state in ('sold', 'rented')">
                <field name="image_256" widget="image" options="{'size': [40, 40]}"/>
                <field name="name"/>
                <field name="property_code"/>
                <field name="property_type"/>
                <field name="project_id"/>
                <field name="region_id"/>
                <field name="sale_lease"/>
                <field name="price" widget="monetary"/>
                <field name="currency_id" invisible="1"/>
                <field name="is_published_portal" widget="boolean_toggle" optional="show"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <!-- ─── Search view with vertical quick-filter sidebar ─────────── -->
    <record id="property_details_view_search" model="ir.ui.view">
        <field name="name">property.details.search</field>
        <field name="model">property.details</field>
        <field name="arch" type="xml">
            <search string="Properties">
                <field name="name"/>
                <field name="property_code"/>
                <field name="project_id"/>
                <field name="region_id"/>
                <field name="owner_id"/>
                <field name="city"/>
                <filter name="filter_available" string="Available" domain="[('state', '=', 'available')]"/>
                <filter name="filter_booked" string="Booked" domain="[('state', '=', 'booked')]"/>
                <filter name="filter_sold" string="Sold" domain="[('state', '=', 'sold')]"/>
                <filter name="filter_rented" string="Rented" domain="[('state', '=', 'rented')]"/>
                <separator/>
                <filter name="filter_for_sale" string="For Sale" domain="[('sale_lease', 'in', ['sale', 'both'])]"/>
                <filter name="filter_for_rent" string="For Rent" domain="[('sale_lease', 'in', ['lease', 'both'])]"/>
                <group>
                    <filter name="groupby_project" string="Project" context="{'group_by': 'project_id'}"/>
                    <filter name="groupby_property_type" string="Property Type" context="{'group_by': 'property_type'}"/>
                    <filter name="groupby_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="groupby_region" string="Region" context="{'group_by': 'region_id'}"/>
                </group>
                <searchpanel>
                    <field name="state" string="Status" icon="fa-flag" select="multi"/>
                    <field name="project_id" string="Project" icon="fa-building" select="multi"/>
                    <field name="property_type" string="Property Type" icon="fa-home" select="multi"/>
                    <field name="sale_lease" string="Sale/Lease" icon="fa-tag" select="multi"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <!-- ─── Kanban view (default) ─────────────────────────────────── -->
    <record id="property_details_kanban_view" model="ir.ui.view">
        <field name="name">property.details.kanban</field>
        <field name="model">property.details</field>
        <field name="type">kanban</field>
        <!-- priority 1 so this canonical v19 kanban wins over a stray Studio/DB-only
             property.details kanban (no XML id) that still calls the removed
             kanban_getcolor() helper and throws OwlError on render -->
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" records_draggable="0" sample="1"
                    decoration-success="state == 'available'"
                    decoration-warning="state == 'booked'"
                    decoration-muted="state in ('sold', 'rented')">
                <field name="state"/>
                <field name="image_512"/>
                <field name="property_type"/>
                <field name="sale_lease"/>
                <field name="price"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click oe_kanban_card p-0 overflow-hidden">
                            <div class="position-relative w-100" style="height:160px;">
                                <t t-if="record.image_512.raw_value">
                                    <field name="image_512" widget="image"
                                           class="w-100 h-100"
                                           options="{'img_class': 'w-100 h-100 object-fit-cover'}"/>
                                </t>
                                <t t-else="">
                                    <div class="bg-300 w-100 h-100 d-flex align-items-center justify-content-center">
                                        <i class="fa fa-home fa-3x text-muted" title="Property"/>
                                    </div>
                                </t>
                                <span class="position-absolute top-0 end-0 m-2">
                                    <field name="state" widget="badge"/>
                                </span>
                            </div>
                            <div class="oe_kanban_details p-2">
                                <div class="fw-bold fs-5 mb-1 text-truncate">
                                    <field name="name"/>
                                </div>
                                <div class="text-muted mb-1">
                                    <field name="property_code"/>
                                </div>
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <span class="badge bg-info">
                                        <field name="property_type"/>
                                    </span>
                                    <span class="badge bg-secondary">
                                        <field name="sale_lease"/>
                                    </span>
                                </div>
                                <div class="fw-bold text-primary">
                                    <field name="price" widget="monetary"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ─── Form view with modern chatter ─────────────────────────── -->
    <record id="property_details_form_view" model="ir.ui.view">
        <field name="name">property.details.form</field>
        <field name="model">property.details</field>
        <field name="arch" type="xml">
            <form string="Property">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="available,booked,sold,rented"/>
                    <button name="action_create_sale_contract" type="object"
                        string="Create Sale Contract" class="btn-primary"
                        invisible="sale_lease not in ['sale', 'both'] or state != 'available'"/>
                    <button name="action_create_rent_contract" type="object"
                        string="Create Rent Contract" class="btn-primary"
                        invisible="sale_lease not in ['lease', 'both'] or state != 'available'"/>
                    <button name="action_create_booking" type="object"
                        string="Book / Hold" class="btn-warning"
                        invisible="state != 'available'"/>
                    <button name="action_publish" type="object" string="Publish"
                        class="btn-primary" invisible="is_published_website"
                        groups="base.group_system"/>
                    <button name="action_unpublish" type="object" string="Unpublish"
                        invisible="not is_published_website"
                        groups="base.group_system"/>
                    <button name="action_archive" type="object" string="Archive"
                        class="btn btn-outline-danger" invisible="not active"
                        groups="base.group_system"/>
                    <button name="action_unarchive" type="object" string="Unarchive"
                        invisible="active"
                        groups="base.group_system"/>
                    <button name="action_print_brochure" type="object" string="Print Brochure"
                        class="btn-primary" icon="fa-print"/>
                    <button name="action_publish_portal" type="object" string="Publish to Portal"
                        class="btn-primary" icon="fa-globe"
                        invisible="is_published_portal"/>
                    <button name="action_unpublish_portal" type="object" string="Unpublish from Portal"
                        class="btn-secondary" icon="fa-globe"
                        invisible="not is_published_portal"/>
                </header>
                <field name="is_published_website" invisible="1"/>
                <field name="is_published_portal" invisible="1"/>
                <field name="maintenance_count" invisible="1"/>
                <field name="document_count" invisible="1"/>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_sale_contracts"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-file-text-o"
                                invisible="sale_lease not in ['sale', 'both']">
                            <field name="sale_contract_count" widget="statinfo" string="Sale Contracts"/>
                        </button>
                        <button name="action_view_rent_contracts"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-home"
                                invisible="sale_lease not in ['lease', 'both']">
                            <field name="rent_contract_count" widget="statinfo" string="Rent Contracts"/>
                        </button>
                        <button name="action_view_maintenance" type="object"
                                class="oe_stat_button" icon="fa-wrench"
                                invisible="maintenance_count &lt;= 0">
                            <field name="maintenance_count" widget="statinfo" string="Maintenance"/>
                        </button>
                        <button name="action_view_documents" type="object"
                                class="oe_stat_button" icon="fa-folder"
                                invisible="document_count &lt;= 0">
                            <field name="document_count" widget="statinfo" string="Documents"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <field name="active" invisible="1"/>
                    <div class="oe_title">
                        <table class="o_inner_group">
                            <tbody>
                                <tr>
                                    <td class="o_avatar">
                                        <field name="image_1920" widget="image" options="{'preview_image': 'image_256', 'size': [96, 96]}" class="o_form_avatar"/>
                                    </td>
                                    <td style="width: 100%">
                                        <label for="name" string="Property Name"/>
                                        <h1>
                                            <field name="name" placeholder="e.g. Marina Heights Tower - Unit 1204"/>
                                        </h1>
                                        <field name="property_code" placeholder="Property Code"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <group>
                        <group string="Classification">
                            <field name="property_type"/>
                            <field name="sale_lease"/>
                            <field name="project_id"/>
                            <field name="sub_project_id"/>
                            <field name="region_id"/>
                        </group>
                        <group string="Ownership">
                            <field name="owner_id"/>
                            <field name="landlord_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Location" name="location">
                            <group>
                                <field name="address"/>
                                <field name="city"/>
                                <field name="state_id"/>
                                <field name="country_id"/>
                                <field name="zip"/>
                            </group>
                        </page>
                        <page string="Specifications" name="specifications">
                            <group>
                                <field name="area"/>
                                <field name="bedrooms"/>
                                <field name="bathrooms"/>
                            </group>
                        </page>
                        <page string="Pricing &amp; Fees" name="pricing">
                            <group>
                                <group>
                                    <field name="currency_id" invisible="1"/>
                                    <field name="sale_price" widget="monetary"/>
                                    <field name="rent_price" widget="monetary"/>
                                    <field name="price" widget="monetary"/>
                                </group>
                                <group>
                                    <field name="dld_fee_percentage"/>
                                    <field name="dld_fee" widget="monetary"/>
                                    <field name="admin_fee_percentage"/>
                                    <field name="admin_fee" widget="monetary"/>
                                </group>
                            </group>
                            <group>
                                <field name="is_payment_plan"/>
                                <field name="payment_schedule_id" invisible="not is_payment_plan"/>
                                <field name="booking_type" invisible="not is_payment_plan"/>
                                <field name="booking_percentage" invisible="not is_payment_plan"/>
                            </group>
                            <group>
                                <field name="is_maintenance_service"/>
                                <field name="total_maintenance" widget="monetary" invisible="not is_maintenance_service"/>
                                <field name="is_extra_service"/>
                                <field name="extra_service_cost" widget="monetary" invisible="not is_extra_service"/>
                                <field name="total_customer_obligation" widget="monetary"/>
                            </group>
                            <separator string="Commission Settings (defaults for new bookings)"/>
                            <group>
                                <group>
                                    <field name="commission_type"/>
                                    <field name="commission_percentage" invisible="commission_type != 'percentage'"/>
                                    <field name="commission_fixed_amount" widget="monetary" invisible="commission_type != 'fixed'"/>
                                    <field name="broker_id"/>
                                    <field name="broker_agency_id"/>
                                </group>
                                <group>
                                    <field name="company_commission_pct"/>
                                    <field name="agent_commission_pct"/>
                                    <field name="referral_commission_pct"/>
                                    <field name="office_commission_pct"/>
                                    <field name="commission_override_pct"/>
                                </group>
                            </group>
                            <group string="Commission Split" name="commission_split">
                                <field name="commission_split_type"/>
                                <field name="commission_split_percentage" invisible="commission_split_type != 'percentage'"/>
                                <field name="commission_split_fixed_amount" widget="monetary" invisible="commission_split_type != 'fixed'"/>
                            </group>
                            <separator string="Aggregated Commission (all bookings)"/>
                            <group>
                                <group>
                                    <field name="total_external_commission" widget="monetary"/>
                                    <field name="total_internal_commission" widget="monetary"/>
                                    <field name="total_commission" widget="monetary"/>
                                </group>
                            </group>
                        </page>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Marketing description, notes..."/>
                        </page>
                        <page string="Amenities &amp; Connectivity" name="amenities_connectivity">
                            <group string="Amenities">
                                <field name="amenity_ids" mode="kanban" options="{'no_create': True}" nolabel="1">
                                    <kanban class="o_kanban_mobile">
                                        <field name="title"/>
                                        <field name="icon_url"/>
                                        <templates>
                                            <t t-name="card">
                                                <div class="oe_kanban_global_click d-flex flex-column align-items-center p-2" style="width:90px;">
                                                    <t t-if="record.icon_url.raw_value">
                                                        <img alt="Amenity"
                                                             t-att-src="record.icon_url.raw_value"
                                                             style="width:48px;height:48px;object-fit:contain;border-radius:50%;"/>
                                                    </t>
                                                    <t t-else="">
                                                        <i class="fa fa-check-circle fa-2x text-primary" title="Amenity"/>
                                                    </t>
                                                    <div class="text-center text-truncate w-100 mt-1">
                                                        <field name="title"/>
                                                    </div>
                                                </div>
                                            </t>
                                        </templates>
                                    </kanban>
                                </field>
                            </group>
                            <group string="Nearby Connectivity">
                                <field name="connectivity_ids" mode="kanban" options="{'no_create': True}" nolabel="1">
                                    <kanban class="o_kanban_mobile">
                                        <field name="name"/>
                                        <field name="icon_url"/>
                                        <templates>
                                            <t t-name="card">
                                                <div class="oe_kanban_global_click d-flex flex-column align-items-center p-2" style="width:90px;">
                                                    <t t-if="record.icon_url.raw_value">
                                                        <img alt="Connectivity"
                                                             t-att-src="record.icon_url.raw_value"
                                                             style="width:48px;height:48px;object-fit:contain;border-radius:50%;"/>
                                                    </t>
                                                    <t t-else="">
                                                        <i class="fa fa-map-marker fa-2x text-primary" title="Connectivity"/>
                                                    </t>
                                                    <div class="text-center text-truncate w-100 mt-1">
                                                        <field name="name"/>
                                                    </div>
                                                </div>
                                            </t>
                                        </templates>
                                    </kanban>
                                </field>
                            </group>
                        </page>
                        <page string="Portal Publishing" name="portal_publishing">
                            <group>
                                <field name="is_published_portal" widget="boolean_toggle"
                                       string="Published on Property Portal"/>
                            </group>
                            <div class="oe_button_box" name="portal_button_box">
                                <button name="action_open_portal_lines" type="object"
                                        class="oe_stat_button" icon="fa-list">
                                    <field name="portal_line_count" widget="statinfo" string="Portal Listings"/>
                                </button>
                                <button name="action_open_portal_leads" type="object"
                                        class="oe_stat_button" icon="fa-envelope">
                                    <field name="portal_lead_count" widget="statinfo" string="Portal Leads"/>
                                </button>
                            </div>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ─── Bulk server actions for portal publishing ─────────────── -->
    <record id="action_property_publish_portal" model="ir.actions.server">
        <field name="name">Publish to Portal</field>
        <field name="model_id" ref="model_property_details"/>
        <field name="binding_model_id" ref="model_property_details"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            if records:
                records.action_publish_portal()
        </field>
    </record>

    <record id="action_property_unpublish_portal" model="ir.actions.server">
        <field name="name">Unpublish from Portal</field>
        <field name="model_id" ref="model_property_details"/>
        <field name="binding_model_id" ref="model_property_details"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            if records:
                records.action_unpublish_portal()
        </field>
    </record>

    <!-- ─── Action: Kanban default, list, form ────────────────────── -->
    <record id="action_property_details" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="res_model">property.details</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="property_details_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your first property!
            </p>
        </field>
    </record>

    <menuitem id="main_menu_rental_management" name="Property Management" sequence="20"/>
    <menuitem id="menu_property_details" name="Properties" parent="main_menu_rental_management"
        action="action_property_details" sequence="1"/>
</odoo>
