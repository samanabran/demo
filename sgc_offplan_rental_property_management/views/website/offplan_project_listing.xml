<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="offplan_project_listing" name="Offplan Project Listing Page">
        <t t-call="website.layout">
            <t t-set="title">Our Projects</t>
            <div class="container my-5">
                <div class="row mb-4">
                    <div class="col-12">
                        <h1 class="mb-2">Our Projects</h1>
                        <p class="text-muted">Explore our premium real estate projects.</p>
                    </div>
                </div>

                <div class="row">
                    <t t-if="projects">
                        <div class="col-md-6 col-lg-4 mb-4" t-foreach="projects" t-as="project">
                            <div class="card h-100 shadow-sm">
                                <div class="position-relative overflow-hidden" style="height:250px;">
                                    <img t-if="project.image_512"
                                         t-att-src="'/web/image/property.project/%s/image_512' % project.id"
                                         class="card-img-top" style="height:100%;width:100%;object-fit:cover;"
                                         t-att-alt="project.name"/>
                                    <img t-else=""
                                         t-att-src="'/web/static/src/img/placeholder.png'"
                                         class="card-img-top" style="height:100%;width:100%;object-fit:cover;"/>
                                </div>
                                <div class="card-body d-flex flex-column">
                                    <h4 class="card-title" t-esc="project.name"/>
                                    <div class="card-text text-muted small" t-out="project.description"/>
                                    <div class="mt-auto d-flex justify-content-between align-items-center">
                                        <span class="badge badge-info">
                                            <t t-esc="project.property_count"/> Properties
                                        </span>
                                        <a t-att-href="'/offplan/project/%s' % project.id"
                                           class="btn btn-sm btn-primary">View Project</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                    <t t-if="not projects">
                        <div class="col-12">
                            <div class="alert alert-info text-center">No projects found.</div>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>
</odoo>
