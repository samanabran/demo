<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="helpdesk_ticket_form_view_inherit_video" model="ir.ui.view">
        <field name="name">helpdesk.ticket.form.video.inherit</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="helpdesk.helpdesk_ticket_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_launch_support_meeting" type="object"
                        class="oe_stat_button" icon="fa-video-camera">
                    <div class="o_stat_info">
                        <field name="video_meeting_count"/>
                        <span class="o_stat_text">Meetings</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
