<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_form_view_inherit_video" model="ir.ui.view">
        <field name="name">sale.order.form.video.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_schedule_demo" type="object"
                        class="oe_stat_button" icon="fa-video-camera">
                    <div class="o_stat_info">
                        <field name="video_meeting_count"/>
                        <span class="o_stat_text">Meetings</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
