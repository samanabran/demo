<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_video_provider_account_tree" model="ir.ui.view">
        <field name="name">video.provider.account.tree</field>
        <field name="model">video.provider.account</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="provider_id"/>
                <field name="state" widget="badge" decoration-success="state=='verified'" decoration-danger="state=='error'" decoration-warning="state=='expired'"/>
                <field name="auth_method"/>
                <field name="user_id"/>
                <field name="meeting_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_video_provider_account_form" model="ir.ui.view">
        <field name="name">video.provider.account.form</field>
        <field name="model">video.provider.account</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_verify_connection" type="object" string="Verify Connection" class="btn-primary"/>
                    <button name="action_revoke_token" type="object" string="Revoke Token" confirm="Revoke OAuth tokens?"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,verified,error"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="provider_id"/>
                            <field name="auth_method"/>
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="user_id"/>
                        </group>
                        <group>
                            <field name="last_verified_date"/>
                            <field name="last_error_message" colspan="2"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="oauth" string="OAuth2" groups="sgc_video_conferencing.group_video_conferencing_admin">
                            <group>
                                <field name="oauth_client_id"/>
                                <field name="oauth_client_secret_encrypted" password="True" class="oe_inline"/>
                                <field name="oauth_redirect_uri"/>
                                <field name="oauth_expires_at"/>
                            </group>
                        </page>
                        <page name="apikey" string="API Key" groups="sgc_video_conferencing.group_video_conferencing_admin">
                            <group>
                                <field name="api_key_encrypted" password="True"/>
                                <field name="api_secret_encrypted" password="True"/>
                            </group>
                        </page>
                        <page name="providerspecific" string="Provider-Specific">
                            <group>
                                <field name="tenant_id"/>
                                <field name="zoom_account_id"/>
                                <field name="jitsi_domain"/>
                                <field name="webex_site_url"/>
                                <field name="zoho_accounts_url"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
