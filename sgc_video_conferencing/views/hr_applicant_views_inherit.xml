<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_applicant_form_view_inherit_video" model="ir.ui.view">
        <field name="name">hr.applicant.form.video.inherit</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_recruitment.hr_applicant_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_schedule_interview" type="object"
                        class="oe_stat_button" icon="fa-video-camera">
                    <div class="o_stat_info">
                        <field name="video_meeting_count"/>
                        <span class="o_stat_text">Interviews</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
