<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="meeting_create_wizard_form" model="ir.ui.view">
        <field name="name">meeting.create.wizard.form</field>
        <field name="model">meeting.create.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Video Meeting">
                <group>
                    <field name="name"/>
                    <field name="provider_id"/>
                    <field name="provider_account_id"/>
                    <field name="meeting_type"/>
                </group>
                <group string="Schedule" invisible="meeting_type == 'instant'">
                    <field name="start_date"/>
                    <field name="start_time"/>
                    <field name="duration_minutes"/>
                </group>
                <group string="Recurrence" invisible="meeting_type != 'recurring'">
                    <field name="is_recurring"/>
                    <field name="recurrence_frequency"/>
                    <field name="recurrence_count"/>
                </group>
                <group string="Attendees">
                    <field name="partner_ids" widget="many2many_tags"/>
                    <field name="attendee_emails" placeholder="Additional email addresses, one per line"/>
                </group>
                <group string="Description">
                    <field name="description"/>
                </group>
                <footer>
                    <button name="action_create_meeting" type="object" string="Create Meeting" class="btn-primary"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_meeting_create_wizard" model="ir.actions.act_window">
        <field name="name">Create Video Meeting</field>
        <field name="res_model">meeting.create.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
