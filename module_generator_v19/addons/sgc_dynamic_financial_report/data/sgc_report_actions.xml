        <field name="name">Balance Sheet</field>
        <field name="res_model">sgc.financial.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_report_type': 'balance_sheet'}</field>
        <field name="view_id" ref="sgc_dfr_wizard_view_form"/>
    </record>

    <menuitem
        id="sgc_dfr_menu_balance_sheet"
        name="Balance Sheet"
        parent="sgc_dfr_menu_root"
        action="sgc_dfr_action_balance_sheet"
        sequence="10"
        groups="sgc_dynamic_financial_report.sgc_dfr_group_user"
    />

