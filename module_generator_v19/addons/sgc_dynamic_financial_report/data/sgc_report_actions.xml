    <!-- ROOT MENU – placed under Accounting > Reports                     -->
    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!-- web_icon is only valid on a true root (parent-less) menuitem; this
         one is nested under Accounting's menu, so it can't declare one -
         the module's App-grid icon is static/description/icon.png instead. -->
    <menuitem
        id="sgc_dfr_menu_root"
        name="SGC Financial Reports"
        parent="account.menu_finance_reports"
        sequence="90"
        groups="sgc_dynamic_financial_report.sgc_dfr_group_user"
    />

