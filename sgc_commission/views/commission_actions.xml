<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Commission Line Action & Views -->
    <record id="view_commission_line_tree" model="ir.ui.view">
        <field name="name">commission.line.tree</field>
        <field name="model">commission.line</field>
        <field name="arch" type="xml">
            <list>
                <field name="sale_order_id"/>
                <field name="partner_id"/>
                <field name="commission_amount"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_commission_line_form" model="ir.ui.view">
        <field name="name">commission.line.form</field>
        <field name="model">commission.line</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="sale_order_id"/>
                        <field name="partner_id"/>
                        <field name="commission_type_id"/>
                        <field name="commission_rate"/>
                        <field name="base_amount"/>
                        <field name="commission_amount"/>
                        <field name="state"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_commission_line" model="ir.actions.act_window">
        <field name="name">Commission Lines</field>
        <field name="res_model">commission.line</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
