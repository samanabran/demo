<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extended Vendor Bill Form View for Commission Details -->
    <record id="view_move_form_commission_enhanced" model="ir.ui.view">
        <field name="name">account.move.form.commission.enhanced</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Add commission details to invoice lines in vendor bills -->
            <xpath expr="//field[@name='invoice_line_ids']//field[@name='name']" position="after">
                <field name="commission_rate" 
                       string="Comm. Rate (%)"
                       optional="show"
                       invisible="not commission_line_id"/>
                <field name="commission_base_amount" 
                       string="Base Amount"
                       optional="show"
                       invisible="not commission_line_id"/>
                <field name="commission_line_id" invisible="1"/>
            </xpath>
        </field>
    </record>

    <!-- Tree View for Account Move Line with Commission Info -->
    <record id="view_invoice_tree_commission" model="ir.ui.view">
        <field name="name">account.move.line.tree.commission</field>
        <field name="model">account.move.line</field>
        <field name="arch" type="xml">
            <list string="Invoice Lines">
                <field name="move_id"/>
                <field name="partner_id"/>
                <field name="name"/>
                <field name="commission_rate" string="Rate (%)"/>
                <field name="commission_base_amount" string="Base Amount"/>
                <field name="price_subtotal" string="Commission Amount"/>
                <field name="commission_line_id" invisible="1"/>
            </list>
        </field>
    </record>
</odoo>
