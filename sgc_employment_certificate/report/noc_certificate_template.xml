<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_noc_certificate">
        <t t-foreach="doc_ids" t-as="doc_id">
            <t t-foreach="docs" t-as="o">
                <div class="page">
                    <h2>No Objection Certificate</h2>
                    <p><strong>Employee:</strong> <span t-esc="o.employee_id.name"/></p>
                    <p><strong>Passport:</strong> <span t-esc="o.passport_number"/></p>
                    <p><strong>Issue Date:</strong> <span t-esc="o.issue_date"/></p>
                </div>
            </t>
        </t>
    </template>
</odoo>
