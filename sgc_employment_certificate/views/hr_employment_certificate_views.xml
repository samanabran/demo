<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_employment_certificate_tree" model="ir.ui.view">
        <field name="name">hr.employment.certificate.tree</field>
        <field name="model">hr.employment.certificate</field>
        <field name="arch" type="xml">
                <list string="Employment Certificates">
                <header>
                    <button name="action_submit_for_approval"
                        string="Submit for Approval"
                        type="object"
                        class="btn-primary"
                        groups="hr.group_hr_user"/>
                    <button name="action_approve"
                        string="Approve"
                        type="object"
                        groups="hr.group_hr_user"/>
                    <button name="action_cancel"
                        string="Cancel"
                        type="object"
                        groups="hr.group_hr_user"/>
                    <button name="action_mark_expired"
                        string="Mark Expired"
                        type="object"
                        groups="hr.group_hr_user"/>
                    <button name="action_remove"
                        string="Remove"
                        type="object"
                        groups="hr.group_hr_user"/>
                </header>
                <field name="reference_number"/>
                <field name="certificate_type"/>
                <field name="employee_id"/>
                <field name="job_position"/>
                <field name="issue_date"/>
                <field name="expiry_date"/>
                <field name="purpose"/>
                <field name="state"/>
                <field name="active" invisible="1"/>
            </list>
        </field>
    </record>

    <record id="hr_employment_certificate_form" model="ir.ui.view">
        <field name="name">hr.employment.certificate.form</field>
        <field name="model">hr.employment.certificate</field>
        <field name="arch" type="xml">
                <form string="Employment Certificate">
                <header>
                        <button name="action_submit_for_approval"
                            string="Submit for Approval"
                            type="object"
                            class="btn-primary"
                            invisible="state not in ('draft', 'issued')"
                            groups="hr.group_hr_user"/>
                        <button name="action_approve"
                            string="Approve"
                            type="object"
                            invisible="state != 'submitted'"
                            groups="hr.group_hr_user"/>
                        <button name="action_mark_issued"
                            string="Mark Issued"
                            type="object"
                            invisible="state != 'approved'"
                            groups="hr.group_hr_user"/>
                        <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            invisible="state in ('cancelled', 'expired')"
                            groups="hr.group_hr_user"/>
                        <button name="action_mark_expired"
                            string="Mark Expired"
                            type="object"
                            invisible="state not in ('issued', 'approved')"
                            groups="hr.group_hr_user"/>
                    <button name="action_remove"
                        string="Remove"
                        type="object"
                        groups="hr.group_hr_user"/>
                    <field name="state"
                       widget="statusbar"
                       statusbar_visible="draft,submitted,approved,issued,cancelled,expired"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="reference_number" readonly="1"/>
                            <field name="certificate_type" readonly="1"/>
                            <field name="employee_id" readonly="1"/>
                            <field name="employment_status" readonly="1"/>
                            <field name="job_position" readonly="1"/>
                        </group>
                        <group>
                            <field name="issue_date" readonly="1"/>
                            <field name="expiry_date" readonly="1"/>
                            <field name="purpose" readonly="1"/>
                            <field name="recipient_name" readonly="1"/>
                            <field name="recipient_title" readonly="1"/>
                            <field name="recipient_organization" readonly="1"/>
                        <field name="requester_user_id" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Employment Details">
                            <field name="join_date" readonly="1"/>
                            <field name="end_date" readonly="1"/>
                            <field name="employment_duration" readonly="1"/>
                            <field name="pronoun" readonly="1"/>
                        </group>
                        <group string="Salary Details">
                            <field name="currency_id" readonly="1"/>
                            <field name="gross_salary" readonly="1"/>
                            <field name="last_salary" readonly="1"/>
                            <field name="show_salary" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Signatory">
                            <field name="signatory_name" readonly="1"/>
                            <field name="signatory_title" readonly="1"/>
                            <field name="digital_signature" readonly="1" widget="image"/>
                        </group>
                        <group string="QR">
                            <field name="qr_image" readonly="1" widget="image"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="hr_employment_certificate_action" model="ir.actions.act_window">
        <field name="name">Issued Certificates</field>
        <field name="res_model">hr.employment.certificate</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No issued certificates yet.
            </p>
        </field>
    </record>

    <menuitem
        id="menu_hr_employment_certificates"
        name="Issued Certificates"
        parent="hr.menu_hr_root"
        action="hr_employment_certificate_action"
        sequence="120"
        groups="hr.group_hr_user"/>
</odoo>
