<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="mail_template_certificate_cancelled" model="mail.template">
        <field name="name">Certificate Cancelled Notification</field>
        <field name="model_id" ref="model_hr_employment_certificate"/>
        <field name="subject">Certificate ${object.reference_number} Cancelled</field>
        <field name="email_from">${(object.company_id.email or user.email or '')|safe}</field>
        <field name="email_to">${object.requester_email or ''}</field>
        <field name="email_cc">${object.hr_department_emails or ''}</field>
        <field name="auto_delete" eval="True"/>
        <field name="body_html" type="html">
            <div>
                <p>Hello,</p>
                <p>
                    The certificate <strong>${object.reference_number}</strong>
                    for <strong>${object.employee_id.name}</strong> has been
                    <strong>cancelled</strong>.
                </p>
                <p>Reason: Cancelled by ${user.name}.</p>
            </div>
        </field>
    </record>

    <record id="mail_template_certificate_expired" model="mail.template">
        <field name="name">Certificate Expired Notification</field>
        <field name="model_id" ref="model_hr_employment_certificate"/>
        <field name="subject">Certificate ${object.reference_number} Expired</field>
        <field name="email_from">${(object.company_id.email or user.email or '')|safe}</field>
        <field name="email_to">${object.requester_email or ''}</field>
        <field name="email_cc">${object.hr_department_emails or ''}</field>
        <field name="auto_delete" eval="True"/>
        <field name="body_html" type="html">
            <div>
                <p>Hello,</p>
                <p>
                    The certificate <strong>${object.reference_number}</strong>
                    for <strong>${object.employee_id.name}</strong> has
                    <strong>expired</strong>.
                </p>
                <p>Expiry Date: ${object.expiry_date or ''}</p>
            </div>
        </field>
    </record>
</odoo>
