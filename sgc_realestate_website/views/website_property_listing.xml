<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Property Listing Page -->
    <template id="property_listing_page" name="Property Listing Page">
        <t t-call="sgc_realestate_website.website_base">
            <div class="container my-5 property-listing-container">
                <div class="row mb-4 align-items-center">
                    <div class="col-md-8 col-sm-12">
                        <h1 class="mb-2">Available Properties</h1>
                        <p class="text-muted">Browse our premium property selection across destinations.</p>
                    </div>
                    <div class="col-md-4 col-sm-12">
                        <form class="search-box" method="get" action="/properties">
                            <div class="input-group">
                                <input type="text" class="form-control" name="search" id="property-search" placeholder="Search city or title" t-att-value="search_term"/>
                                <div class="input-group-append">
                                    <button class="btn btn-primary" type="submit" id="search-button">
                                        <span class="fa fa-search" title="Search"></span>
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Filters -->
                <form class="filter-section card mb-4" method="get" action="/properties">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-3 col-sm-6 mb-3">
                                <label class="font-weight-medium" for="filter-country">Country</label>
                                <select class="form-control" id="filter-country" name="country">
                                    <option value="">All Countries</option>
                                    <option t-foreach="countries" t-as="country" t-att-value="country.id" t-att-selected="'selected' if filters.get('country') == str(country.id) else None" t-esc="country.name"/>
                                </select>
                            </div>
                            <div class="col-md-3 col-sm-6 mb-3">
                                <label class="font-weight-medium" for="filter-type">Type</label>
                                <select class="form-control" id="filter-type" name="property_type">
                                    <option value="">All Types</option>
                                    <option t-foreach="property_types.items()" t-as="ptype" t-att-value="ptype[0]" t-att-selected="'selected' if filters.get('property_type') == ptype[0] else None" t-esc="ptype[1]"/>
                                </select>
                            </div>
                            <div class="col-md-3 col-sm-6 mb-3">
                                <label class="font-weight-medium" for="filter-sale-lease">Sale / Rent</label>
                                <select class="form-control" id="filter-sale-lease" name="sale_lease">
                                    <option value="">Sale or Rent</option>
                                    <option value="for_sale" t-att-selected="'selected' if filters.get('sale_lease') == 'for_sale' else None">For Sale</option>
                                    <option value="for_rent" t-att-selected="'selected' if filters.get('sale_lease') == 'for_rent' else None">For Rent</option>
                                </select>
                            </div>
                            <div class="col-md-3 col-sm-6 mb-3">
                                <label class="font-weight-medium" for="min-price">Min Price</label>
                                <input type="number" class="form-control" id="min-price" name="min_price" min="0" step="1000" t-att-value="filters.get('min_price')" placeholder="e.g. 100000"/>
                            </div>
                            <div class="col-md-3 col-sm-6 mb-3">
                                <label class="font-weight-medium" for="max-price">Max Price</label>
                                <input type="number" class="form-control" id="max-price" name="max_price" min="0" step="1000" t-att-value="filters.get('max_price')" placeholder="e.g. 500000"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-3 col-sm-6 mb-3">
                                <label class="font-weight-medium" for="filter-bedrooms">Bedrooms</label>
                                <input type="number" class="form-control" id="filter-bedrooms" name="bedrooms" min="0" step="1" t-att-value="filters.get('bedrooms')"/>
                            </div>
                            <div class="col-md-3 col-sm-6 mb-3">
                                <label class="font-weight-medium" for="filter-bathrooms">Bathrooms</label>
                                <input type="number" class="form-control" id="filter-bathrooms" name="bathrooms" min="0" step="1" t-att-value="filters.get('bathrooms')"/>
                            </div>
                            <div class="col-md-3 col-sm-6 mb-3">
                                <label class="font-weight-medium" for="filter-sort">Sort By</label>
                                <select class="form-control" id="filter-sort" name="sort">
                                    <option value="newest" t-att-selected="'selected' if filters.get('sort') == 'newest' else None">Newest</option>
                                    <option value="price_asc" t-att-selected="'selected' if filters.get('sort') == 'price_asc' else None">Price: Low to High</option>
                                    <option value="price_desc" t-att-selected="'selected' if filters.get('sort') == 'price_desc' else None">Price: High to Low</option>
                                </select>
                            </div>
                            <div class="col-md-3 col-sm-6 d-flex align-items-end">
                                <button class="btn btn-primary btn-block w-100" type="submit">
                                    <span class="fa fa-filter" title="Apply filters"></span> Apply Filters
                                </button>
                            </div>
                        </div>
                    </div>
                </form>

                <!-- Property Grid -->
                <div class="property-grid">
                    <div class="row" id="propertyContainer">
                        <t t-if="properties">
                            <div class="col-md-6 col-lg-4 mb-4" t-foreach="properties" t-as="prop">
                                <div class="property-card card h-100 shadow-sm" t-att-data-country="prop.destination_country_id.id" t-att-data-type="prop.property_type" t-att-data-price="prop.price">
                                    <div class="position-relative overflow-hidden" style="height: 250px;">
                                        <img t-if="prop.image_1920" t-att-src="'/web/image/sgc.realestate.property/%s/image_512' % prop.id" class="card-img-top" style="height: 100%; object-fit: cover;" t-att-alt="prop.title"/>
                                        <div class="position-absolute" style="top: 10px; right: 10px;">
                                            <span class="badge badge-primary" t-esc="(prop.property_type or '').title()"/>
                                        </div>
                                    </div>
                                    <div class="card-body d-flex flex-column">
                                        <h5 class="card-title" t-esc="prop.title or prop.name"/>
                                        <p class="text-muted small mb-2 property-location">
                                            <span class="fa fa-map-marker" title="Location"></span>
                                            <span t-esc="prop.city"/>,
                                            <span t-esc="prop.destination_country_id.name"/>
                                        </p>
                                        <div class="mb-3">
                                            <span class="badge badge-info mr-1" t-esc="('%s bed' % prop.bedrooms) if prop.bedrooms else 'Studio'"/>
                                            <span class="badge badge-info mr-1" t-esc="('%s bath' % prop.bathrooms) if prop.bathrooms else '1 bath'"/>
                                            <span class="badge badge-info" t-esc="('%s sqm' % prop.area) if prop.area else ''"/>
                                        </div>
                                        <p class="card-text small text-muted flex-grow-1" t-esc="prop.description and prop.description[:120]"/>
                                        <div class="d-flex justify-content-between align-items-center mt-auto">
                                            <h4 class="text-primary mb-0" t-esc="'%s %.0f' % (prop.currency_id.symbol or '$', prop.price)"/>
                                            <a t-att-href="prop.website_url or ('/property/%s' % prop.id)" class="btn btn-sm btn-outline-primary">
                                                View Details
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                        <t t-if="not properties">
                            <div class="col-12">
                                <div class="alert alert-info text-center" id="noResults">
                                    <span class="fa fa-info-circle" title="No results"></span> No properties found. Try adjusting your filters.
                                </div>
                            </div>
                        </t>
                    </div>
                </div>

                <t t-if="pager">
                    <div class="mt-4">
                        <t t-call="website.pager">
                            <t t-set="page" t-value="pager['page']"/>
                            <t t-set="page_count" t-value="pager['page_count']"/>
                            <t t-set="step" t-value="pager['step']"/>
                            <t t-set="scope" t-value="pager.get('scope') if hasattr(pager, 'get') else pager['step']"/>
                            <t t-set="url_args" t-value="pager['url_args']"/>
                            <t t-set="url" t-value="pager['url']"/>
                        </t>
                    </div>
                </t>
            </div>
        </t>
    </template>

</odoo>
