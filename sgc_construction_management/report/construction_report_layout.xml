<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Portrait A4 paper format for standard construction reports.
         margin_top must be large enough to hold the whole header band:
         wkhtmltopdf clips (does not shrink) a header taller than the margin. -->
    <record id="paperformat_construction_portrait" model="report.paperformat">
        <field name="name">Construction A4 Portrait</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">32</field>
        <field name="margin_bottom">26</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">27</field>
        <field name="dpi">90</field>
    </record>

    <!-- Styling lives in static/src/css/construction_report.css
         (web.report_assets_common), scoped under .sgc-report. An inline
         <style> here never reaches wkhtmltopdf: Odoo rebuilds the PDF
         body/header/footer from the .article/.header/.footer divs only. -->
    <template id="construction_external_layout">
        <t t-if="not o" t-set="o" t-value="doc"/>
        <t t-if="not company" t-set="company" t-value="res_company"/>

        <div class="header sgc-report">
            <div class="row" style="align-items: center;">
                <div class="col-3">
                    <img t-if="company.logo" t-att-src="image_data_uri(company.logo)" style="max-height: 42px; max-width: 100%;" alt="Company Logo"/>
                </div>
                <div class="col-6 text-center">
                    <strong style="font-size:13px;"><t t-esc="company.name"/></strong>
                    <div style="font-size:9px; line-height:1.3;">
                        <t t-if="company.street"><t t-esc="company.street"/></t>
                        <t t-if="company.city"><t t-if="company.street"> , </t><t t-esc="company.city"/></t>
                        <t t-if="company.country_id">, <t t-esc="company.country_id.name"/></t>
                    </div>
                    <div t-if="company.website" style="font-size:8px; color:#6c757d;"><t t-esc="company.website"/></div>
                </div>
                <div class="col-3 text-end" style="font-size:9px;">
                    <!-- Use o._fields.get() — safe in QWeb eval; 'field' in record is NOT supported -->
                    <t t-if="o and o._name != 'construction.project' and o._fields.get('project_id')">
                        <div style="font-weight:bold;">Project: <t t-esc="o.project_id.name"/></div>
                    </t>
                    <t t-if="o and o._name == 'construction.project'">
                        <div style="font-weight:bold;"><t t-esc="o.name"/></div>
                    </t>
                    <t t-elif="o and o._name == 'construction.ra.billing'">
                        <div><t t-esc="o.ra_number"/></div>
                    </t>
                    <t t-elif="o and o._name == 'construction.progress.billing'">
                        <div><t t-esc="o.ref"/></div>
                    </t>
                </div>
            </div>
            <div style="border-bottom: 2px solid #212529; margin-top: 6px;"/>
        </div>

        <div class="article sgc-report" t-att-data-oe-model="o and o._name" t-att-data-oe-id="o and o.id">
            <t t-out="0"/>
        </div>

        <div class="footer sgc-report">
            <div class="text-center" style="border-top: 1px solid #212529; font-size: 8px; padding-top: 4px;">
                <div class="row" style="margin-top: 3px;">
                    <div class="col-4">
                        <strong>Prepared By:</strong><br/>
                        <span style="letter-spacing:1px;">____________________</span><br/>
                        <!-- o._fields.get() avoids KeyError when field absent on this model -->
                        <t t-if="o and o._fields.get('prepared_by') and o.prepared_by"><t t-esc="o.prepared_by.name"/></t>
                        <t t-else="">Signature</t>
                    </div>
                    <div class="col-4">
                        <strong>Checked By:</strong><br/>
                        <span style="letter-spacing:1px;">____________________</span><br/>
                        <span>Project Manager / QS</span>
                    </div>
                    <div class="col-4">
                        <strong>Approved By:</strong><br/>
                        <span style="letter-spacing:1px;">____________________</span><br/>
                        <span>Client / Consultant</span>
                    </div>
                </div>
                <div class="text-muted" style="margin-top: 4px;">
                    Page <span class="page"/> of <span class="topage"/> |
                    Printed on: <t t-esc="datetime.date.today().strftime('%d %b %Y')"/> |
                    <t t-esc="company.name"/>
                </div>
            </div>
        </div>
    </template>
</odoo>
