<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- RA Billing List View -->
    <record id="view_construction_ra_billing_list" model="ir.ui.view">
        <field name="name">construction.ra.billing.list</field>
        <field name="model">construction.ra.billing</field>
        <field name="arch" type="xml">
            <list>
                <field name="ref"/>
                <field name="name"/>
                <field name="project_id"/>
                <field name="billing_date"/>
                <field name="billing_period_start"/>
                <field name="billing_period_end"/>
                <field name="total_amount"/>
                <field name="net_payable"/>
                <field name="state" widget="badge"
                    decoration-success="state in ('approved', 'posted', 'paid')"
                    decoration-info="state in ('submitted', 'invoice_created')"
                    decoration-warning="state == 'draft'"/>
            </list>
        </field>
    </record>

    <!-- RA Billing Form View -->
    <record id="view_construction_ra_billing_form" model="ir.ui.view">
        <field name="name">construction.ra.billing.form</field>
        <field name="model">construction.ra.billing</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" type="object" string="Submit"
                        invisible="state != 'draft'" class="btn-primary"/>
                    <button name="action_approve" type="object" string="Approve"
                        invisible="state != 'submitted'" class="btn-success"/>
                    <button name="action_load_boq" type="object" string="Load BOQ Lines"
                        invisible="state != 'draft'" class="btn-secondary"/>
                    <button name="action_create_invoice" type="object" string="Create Invoice"
                        invisible="state != 'approved'" class="btn-primary" groups="sgc_construction_management.group_construction_finance"/>
                    <button name="action_pay" type="object" string="Mark Paid"
                        invisible="state != 'posted'" class="btn-primary"/>
                    <button name="action_cancel" type="object" string="Cancel Invoice"
                        invisible="state != 'invoice_created'" class="btn-danger"
                        groups="sgc_construction_management.group_construction_finance"/>
                    <button name="action_reopen_invoice" type="object" string="Reopen Invoice"
                        invisible="move_state != 'cancel'" class="btn-primary"
                        groups="sgc_construction_management.group_construction_finance"/>
                    <button name="action_reset" type="object" string="Reset to Draft"
                        invisible="state not in ('submitted', 'approved', 'invoice_created')"
                        class="btn-warning"/>
                    <field name="move_state" invisible="1"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,invoice_created,posted,paid"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_invoice" type="object" class="oe_stat_button" icon="fa-pencil-square-o" invisible="not move_id">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Invoice</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                        <div><field name="ref" readonly="1"/></div>
                    </div>
                    <group>
                        <group string="Billing Details">
                            <field name="project_id"/>
                            <field name="billing_date"/>
                            <field name="billing_period_start"/>
                            <field name="billing_period_end"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Summary">
                            <field name="previous_billed"/>
                            <field name="retention_percent"/>
                            <field name="move_id" invisible="1"/>
                            <field name="payment_state" widget="badge" decoration-success="payment_state == 'paid'" decoration-info="payment_state == 'partial'" invisible="not move_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Billing Lines">
                            <field name="line_ids" widget="one2many">
                                <list editable="bottom">
                                    <field name="boq_line_id"/>
                                    <field name="boq_line_description"/>
                                    <field name="work_type"/>
                                    <field name="uom_id"/>
                                    <field name="boq_qty"/>
                                    <field name="qty_previous"/>
                                    <field name="qty_current"/>
                                    <field name="qty_cumulative" readonly="1"/>
                                    <field name="unit_rate"/>
                                    <field name="amount" readonly="1"/>
                                    <field name="currency_id" invisible="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                    <group class="oe_subtotal_footer oe_right">
                        <field name="total_amount" readonly="1"/>
                        <field name="previous_billed" readonly="1"/>
                        <field name="net_amount" readonly="1"/>
                        <field name="retention_amount" readonly="1"/>
                        <div class="oe_subtotal_footer_separator oe_inline o_td_label">
                            <label for="net_payable"/>
                        </div>
                        <field name="net_payable" readonly="1" nolabel="1" class="oe_subtotal_footer_separator"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- RA Billing Action -->
    <record id="action_construction_ra_billing" model="ir.actions.act_window">
        <field name="name">RA Billing</field>
        <field name="res_model">construction.ra.billing</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Progress Billing List View -->
    <record id="view_construction_progress_billing_list" model="ir.ui.view">
        <field name="name">construction.progress.billing.list</field>
        <field name="model">construction.progress.billing</field>
        <field name="arch" type="xml">
            <list>
                <field name="ref"/>
                <field name="name"/>
                <field name="project_id"/>
                <field name="billing_date"/>
                <field name="percent_complete" string="% Complete"/>
                <field name="amount_earned"/>
                <field name="amount_this_period"/>
                <field name="state" widget="badge"
                    decoration-success="state in ('approved', 'posted')"
                    decoration-info="state == 'invoice_created'"
                    decoration-warning="state == 'draft'"/>
            </list>
        </field>
    </record>

    <!-- Progress Billing Form View -->
    <record id="view_construction_progress_billing_form" model="ir.ui.view">
        <field name="name">construction.progress.billing.form</field>
        <field name="model">construction.progress.billing</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_approve" type="object" string="Approve"
                        invisible="state != 'draft'" class="btn-success"/>
                    <button name="action_create_invoice" type="object" string="Create Invoice"
                        invisible="state != 'approved'" class="btn-primary" groups="sgc_construction_management.group_construction_finance"/>
                    <button name="action_cancel" type="object" string="Cancel Invoice"
                        invisible="state != 'invoice_created'" class="btn-danger"
                        groups="sgc_construction_management.group_construction_finance"/>
                    <button name="action_reopen_invoice" type="object" string="Reopen Invoice"
                        invisible="move_state != 'cancel'" class="btn-primary"
                        groups="sgc_construction_management.group_construction_finance"/>
                    <button name="action_reset" type="object" string="Reset to Draft"
                        invisible="state not in ('approved', 'invoice_created')" class="btn-warning"/>
                    <field name="move_state" invisible="1"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,approved,invoice_created,posted"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_invoice" type="object" class="oe_stat_button" icon="fa-pencil-square-o" invisible="not move_id">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Invoice</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                        <div><field name="ref" readonly="1"/></div>
                    </div>
                    <group>
                        <group string="Details">
                            <field name="project_id"/>
                            <field name="billing_date"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Progress">
                            <field name="contract_value" readonly="1"/>
                            <field name="percent_complete"/>
                            <field name="amount_earned" readonly="1"/>
                            <field name="amount_previously_billed"/>
                            <field name="amount_this_period" readonly="1"/>
                            <field name="move_id" invisible="1"/>
                            <field name="payment_state" widget="badge" decoration-success="payment_state == 'paid'" decoration-info="payment_state == 'partial'" invisible="not move_id"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Progress Billing Action -->
    <record id="action_construction_progress_billing" model="ir.actions.act_window">
        <field name="name">Progress Billing</field>
        <field name="res_model">construction.progress.billing</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
