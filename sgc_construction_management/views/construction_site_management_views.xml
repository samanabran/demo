<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Site Diary -->
    <record id="view_construction_site_diary_tree" model="ir.ui.view">
        <field name="name">construction.site.diary.tree</field>
        <field name="model">construction.site.diary</field>
        <field name="arch" type="xml">
            <list>
                <field name="date"/>
                <field name="project_id"/>
                <field name="weather"/>
                <field name="prepared_by"/>
            </list>
        </field>
    </record>

    <record id="view_construction_site_diary_form" model="ir.ui.view">
        <field name="name">construction.site.diary.form</field>
        <field name="model">construction.site.diary</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="date"/>
                            <field name="prepared_by"/>
                        </group>
                        <group>
                            <field name="weather"/>
                            <field name="temperature"/>
                            <field name="shift"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Labor">
                            <field name="labor_summary_ids">
                                <list editable="bottom">
                                    <field name="trade"/>
                                    <field name="contractor_id"/>
                                    <field name="planned_qty"/>
                                    <field name="actual_qty"/>
                                </list>
                            </field>
                        </page>
                        <page string="Equipment">
                            <field name="equipment_summary_ids">
                                <list editable="bottom">
                                    <field name="equipment_id"/>
                                    <field name="hours_utilized"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>
                        <page string="Activities">
                            <field name="activity_ids">
                                <list editable="bottom">
                                    <field name="wbs_id"/>
                                    <field name="description"/>
                                    <field name="progress_percent"/>
                                </list>
                            </field>
                        </page>
                        <page string="Issues">
                            <field name="issue_ids">
                                <list editable="bottom">
                                    <field name="issue_type"/>
                                    <field name="description"/>
                                    <field name="impact_hours"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                    <group string="Remarks">
                        <field name="remarks" nolabel="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Equipment -->
    <record id="view_construction_equipment_tree" model="ir.ui.view">
        <field name="name">construction.equipment.tree</field>
        <field name="model">construction.equipment</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="category"/>
                <field name="status" widget="badge"
                    decoration-success="status == 'operational'"
                    decoration-warning="status == 'maintenance'"
                    decoration-danger="status == 'breakdown'"
                    decoration-info="status == 'idle'"/>
            </list>
        </field>
    </record>

    <record id="view_construction_equipment_form" model="ir.ui.view">
        <field name="name">construction.equipment.form</field>
        <field name="model">construction.equipment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Caterpillar Excavator 320"/></h1>
                        <div><field name="code" placeholder="Equipment Code..."/></div>
                    </div>
                    <group>
                        <group>
                            <field name="category"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <!-- Placeholder for more fields like serial number, brand, etc. -->
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_construction_site_diary" model="ir.actions.act_window">
        <field name="name">Site Diaries</field>
        <field name="res_model">construction.site.diary</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_construction_equipment" model="ir.actions.act_window">
        <field name="name">Equipment</field>
        <field name="res_model">construction.equipment</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_construction_labor_attendance" model="ir.actions.act_window">
        <field name="name">Labor Attendance</field>
        <field name="res_model">construction.labor.attendance</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
