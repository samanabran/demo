<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Project List View -->
    <record id="view_construction_project_list" model="ir.ui.view">
        <field name="name">construction.project.list</field>
        <field name="model">construction.project</field>
        <field name="arch" type="xml">
            <list>
                <field name="ref"/>
                <field name="name"/>
                <field name="client_id"/>
                <field name="project_manager_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="contract_value"/>
                <field name="total_billed"/>
                <field name="total_expenses"/>
                <field name="progress" widget="progressbar"/>
                <field name="billing_percent" widget="progressbar"/>
                <field name="receipt_percent" widget="progressbar"/>
                <field name="expense_vs_billed_percent" widget="progressbar"/>
                <field name="state" widget="badge"
                    decoration-success="state in ('active', 'completed')"
                    decoration-warning="state in ('draft', 'on_hold')"
                    decoration-danger="state == 'cancelled'"
                    decoration-info="state == 'completed'"/>
            </list>
        </field>
    </record>

    <!-- Project Form View -->
    <record id="view_construction_project_form" model="ir.ui.view">
        <field name="name">construction.project.form</field>
        <field name="model">construction.project</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_activate" type="object" string="Activate"
                        invisible="state != 'draft'" class="btn-success"/>
                    <button name="action_hold" type="object" string="On Hold"
                        invisible="state != 'active'"/>
                    <button name="action_complete" type="object" string="Complete"
                        invisible="state not in ('active', 'on_hold')" class="btn-success"/>
                    <button name="action_cancel" type="object" string="Cancel"
                        invisible="state not in ('draft', 'active', 'on_hold')"
                        class="btn-danger"/>
                    <button name="action_reset" type="object" string="Reset to Draft"
                        invisible="state != 'cancelled'"
                        class="btn-warning"/>
                    <button name="action_export_wip_xlsx" type="object" string="Export WIP (XLSX)"
                        class="btn-secondary"/>
                    <button name="%(sgc_construction_management.action_report_project_soa)d" type="action"
                        string="Statement of Account" class="btn-secondary"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,completed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_boq" type="object" class="oe_stat_button" icon="fa-file-text">
                            <field name="boq_count" widget="statinfo" string="BOQ"/>
                        </button>
                        <button name="action_view_wbs" type="object" class="oe_stat_button" icon="fa-sitemap">
                            <field name="wbs_count" widget="statinfo" string="WBS Phases"/>
                        </button>
                        <button name="action_view_work_orders" type="object" class="oe_stat_button" icon="fa-wrench">
                            <field name="work_order_count" widget="statinfo" string="Work Orders"/>
                        </button>
                        <button name="action_view_requisitions" type="object" class="oe_stat_button" icon="fa-shopping-cart">
                            <field name="material_requisition_count" widget="statinfo" string="Requisitions"/>
                        </button>
                        <button name="action_view_subcontracts" type="object" class="oe_stat_button" icon="fa-handshake-o">
                            <field name="subcontract_count" widget="statinfo" string="Subcontracts"/>
                        </button>
                        <button name="action_view_billing" type="object" class="oe_stat_button" icon="fa-money">
                            <field name="billing_count" widget="statinfo" string="RA Billing"/>
                        </button>
                        <button name="action_view_quality" type="object" class="oe_stat_button" icon="fa-check-circle">
                            <field name="quality_check_count" widget="statinfo" string="Quality"/>
                        </button>
                        <button name="action_view_expenses" type="object" class="oe_stat_button" icon="fa-credit-card">
                            <field name="expense_count" widget="statinfo" string="Expenses"/>
                        </button>
                        <button name="action_view_invoices" type="object" class="oe_stat_button" icon="fa-pencil-square-o">
                            <field name="invoice_count" widget="statinfo" string="Invoices"/>
                        </button>
                        <button name="action_view_vendor_bills" type="object" class="oe_stat_button" icon="fa-book">
                            <field name="vendor_bill_count" widget="statinfo" string="Vendor Bills"/>
                        </button>
                        <button name="action_view_documents" type="object" class="oe_stat_button" icon="fa-folder-open">
                            <field name="document_count" widget="statinfo" string="Documents"/>
                        </button>
                        <button name="action_view_variation_orders" type="object" class="oe_stat_button" icon="fa-exchange">
                            <field name="vo_count" widget="statinfo" string="Variations"/>
                        </button>
                    </div>
                    <field name="image_1920" widget="image" class="oe_avatar"
                           options="{'preview_image': 'image_128'}"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Project Name..."/></h1>
                        <div class="o_row">
                            <field name="ref" readonly="1"/>
                        </div>
                    </div>
                    <group>
                        <group string="Project Details">
                            <field name="client_id"/>
                            <field name="project_manager_id"/>
                            <field name="site_manager_id"/>
                            <field name="location"/>
                            <field name="latitude"/>
                            <field name="longitude"/>
                            <field name="emirate"/>
                            <field name="analytic_account_id" readonly="1" groups="account.group_account_readonly"/>
                        </group>
                        <group string="Dates &amp; Contract">
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="contract_value"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Financial Summary" col="4">
                        <field name="total_billed" readonly="1"/>
                        <field name="total_expenses" readonly="1"/>
                        <field name="progress" widget="progressbar" display_label="false"/>
                        <field name="billing_percent" widget="progressbar" display_label="false"/>
                        <field name="receipt_percent" widget="progressbar" display_label="false"/>
                        <field name="expense_vs_billed_percent" widget="progressbar" display_label="false"/>
                    </group>
                    <notebook>
                        <page string="Description" name="description_page">
                            <field name="description" widget="html" nolabel="1"
                                   placeholder="Project description, scope notes... (type / for the Powerbox, then use Ask SGC AI to draft this with AI)"/>
                        </page>
                        <page string="Site Photos" name="site_photos">
                            <field name="photo_ids">
                                <list editable="bottom">
                                    <field name="date"/>
                                    <field name="name"/>
                                    <field name="taken_by_id"/>
                                    <field name="image_128" widget="image" options="{'size': [64, 64]}"/>
                                    <field name="original_file" widget="binary" filename="original_filename"
                                        string="Original Photo"/>
                                    <field name="original_filename" column_invisible="1"/>
                                </list>
                                <form>
                                    <group>
                                        <field name="name"/>
                                        <field name="date"/>
                                        <field name="taken_by_id"/>
                                    </group>
                                    <group>
                                        <field name="image_1920" widget="image"/>
                                        <field name="original_file" widget="binary" filename="original_filename"
                                            string="Original Photo File (preserved as-is)"/>
                                        <field name="original_filename" invisible="1"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                        <page string="Contract Documents" name="contract_docs">
                            <field name="contract_doc_ids">
                                <list editable="bottom">
                                    <field name="date"/>
                                    <field name="name"/>
                                    <field name="category"/>
                                    <field name="original_file" widget="binary" filename="original_filename"/>
                                    <field name="original_filename" column_invisible="1"/>
                                </list>
                                <form>
                                    <group>
                                        <field name="name"/>
                                        <field name="category"/>
                                        <field name="date"/>
                                    </group>
                                    <group string="Document File">
                                        <field name="original_file" widget="binary" filename="original_filename"
                                            string="Upload File (PDF, Excel, Word, etc.)"/>
                                        <field name="original_filename" invisible="1"/>
                                        <field name="notes"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Project Kanban View -->
    <record id="view_construction_project_kanban" model="ir.ui.view">
        <field name="name">construction.project.kanban</field>
        <field name="model">construction.project</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="state">
                <field name="name"/>
                <field name="ref"/>
                <field name="client_id"/>
                <field name="state"/>
                <field name="contract_value"/>
                <field name="progress"/>
                <field name="billing_percent" widget="progressbar" display_label="false"/>
                <field name="receipt_percent" widget="progressbar" display_label="false"/>
                <field name="expense_vs_billed_percent" widget="progressbar" display_label="false"/>
                <templates>
                    <t t-name="kanban-card">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div class="text-muted small">
                                    <field name="ref"/> | <field name="client_id"/>
                                </div>
                                <div class="mt-2">
                                    <field name="progress" widget="progressbar"/>
                                    <field name="billing_percent" widget="progressbar" display_label="false"/>
                                    <field name="receipt_percent" widget="progressbar" display_label="false"/>
                                    <field name="expense_vs_billed_percent" widget="progressbar" display_label="false"/>
                                </div>
                                <div class="mt-1">
                                    <field name="contract_value"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Project Action -->
    <record id="action_construction_project" model="ir.actions.act_window">
        <field name="name">Projects</field>
        <field name="res_model">construction.project</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{}</field>
    </record>
</odoo>