<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Document Folders -->
    <record id="view_construction_document_folder_tree" model="ir.ui.view">
        <field name="name">construction.document.folder.tree</field>
        <field name="model">construction.document.folder</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="project_id"/>
                <field name="document_count"/>
            </list>
        </field>
    </record>

    <record id="view_construction_document_folder_form" model="ir.ui.view">
        <field name="name">construction.document.folder.form</field>
        <field name="model">construction.document.folder</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="project_id"/>
                        <field name="parent_id"/>
                        <field name="sequence"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Documents -->
    <record id="view_construction_document_tree" model="ir.ui.view">
        <field name="name">construction.document.tree</field>
        <field name="model">construction.document</field>
        <field name="arch" type="xml">
            <list decoration-info="status == 'draft'" decoration-success="status == 'approved'" decoration-muted="status == 'closed'">
                <field name="number"/>
                <field name="name"/>
                <field name="category"/>
                <field name="project_id"/>
                <field name="revision_no"/>
                <field name="status"/>
                <field name="issue_date"/>
                <field name="amount" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_construction_document_form" model="ir.ui.view">
        <field name="name">construction.document.form</field>
        <field name="model">construction.document</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="draft,issued,reviewed,approved,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="number"/></h1>
                        <label for="name" class="oe_edit_only"/>
                        <h2><field name="name" placeholder="Document Title"/></h2>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="folder_id"/>
                            <field name="category"/>
                        </group>
                        <group>
                            <field name="issue_date"/>
                            <field name="current_revision_id"/>
                            <field name="amount"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Revisions">
                            <field name="revision_ids">
                                <list editable="bottom">
                                    <field name="revision_no"/>
                                    <field name="revision_date"/>
                                    <field name="status"/>
                                    <field name="file" widget="binary" filename="file_name"/>
                                    <field name="file_name" column_invisible="1"/>
                                    <field name="attachment_id" optional="hide"/>
                                    <field name="prepared_by"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_construction_document_search" model="ir.ui.view">
        <field name="name">construction.document.search</field>
        <field name="model">construction.document</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="number"/>
                <field name="project_id"/>
                <field name="category"/>
                <filter string="My Project's Documents" name="my_project" domain="[('project_id.project_manager_id', '=', uid)]"/>
                <group name="group_by">
                    <filter string="Project" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Category" name="group_category" context="{'group_by': 'category'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_construction_document" model="ir.actions.act_window">
        <field name="name">Documents</field>
        <field name="res_model">construction.document</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_group_project': 1}</field>
    </record>

    <record id="action_construction_document_folder" model="ir.actions.act_window">
        <field name="name">Folders</field>
        <field name="res_model">construction.document.folder</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Variation Orders: dedicated entry point. A VO is a construction.document
         of category 'VO'; this action filters to them and defaults new records
         to that category so logging a variation is a single, obvious step. -->
    <record id="action_construction_variation_order" model="ir.actions.act_window">
        <field name="name">Variation Orders</field>
        <field name="res_model">construction.document</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('category', '=', 'VO')]</field>
        <field name="context">{'default_category': 'VO', 'search_default_group_project': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Log a variation order</p>
            <p>Record each agreed scope change with its amount. Variations appear on the project's VO Register report.</p>
        </field>
    </record>
</odoo>
