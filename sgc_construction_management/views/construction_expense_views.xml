<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Expense Category Views -->
    <record id="view_construction_expense_category_list" model="ir.ui.view">
        <field name="name">construction.expense.category.list</field>
        <field name="model">construction.expense.category</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="property_account_expense_id"/>
            </list>
        </field>
    </record>

    <!-- Expense List View -->
    <record id="view_construction_expense_list" model="ir.ui.view">
        <field name="name">construction.expense.list</field>
        <field name="model">construction.expense</field>
        <field name="arch" type="xml">
            <list>
                <field name="ref"/>
                <field name="name"/>
                <field name="project_id"/>
                <field name="wbs_id"/>
                <field name="date"/>
                <field name="category_id"/>
                <field name="employee_id"/>
                <field name="amount"/>
                <field name="state" widget="badge"
                    decoration-success="state in ('approved', 'posted')"
                    decoration-info="state in ('submitted', 'bill_created')"
                    decoration-danger="state == 'rejected'"
                    decoration-warning="state == 'draft'"/>
            </list>
        </field>
    </record>

    <!-- Expense Form View -->
    <record id="view_construction_expense_form" model="ir.ui.view">
        <field name="name">construction.expense.form</field>
        <field name="model">construction.expense</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" type="object" string="Submit"
                        invisible="state != 'draft'" class="btn-primary"/>
                    <button name="action_approve" type="object" string="Approve"
                        invisible="state != 'submitted'" class="btn-success"/>
                    <button name="action_create_bill" type="object" string="Create Bill"
                        invisible="state != 'approved'" class="btn-primary" groups="sgc_construction_management.group_construction_finance"/>
                    <button name="action_reject" type="object" string="Reject"
                        invisible="state != 'submitted'" class="btn-danger"/>
                    <button name="action_cancel" type="object" string="Cancel Bill"
                        invisible="state != 'bill_created'" class="btn-secondary"
                        groups="sgc_construction_management.group_construction_finance"/>
                    <button name="action_reopen_bill" type="object" string="Reopen Bill"
                        invisible="move_state != 'cancel'" class="btn-primary"
                        groups="sgc_construction_management.group_construction_finance"/>
                    <button name="action_reset" type="object" string="Reset to Draft"
                        invisible="state in ('draft', 'posted')" class="btn-warning"/>
                    <field name="move_state" invisible="1"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,bill_created,posted"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_bill" type="object" class="oe_stat_button" icon="fa-book" invisible="not move_id">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Vendor Bill</span>
                            </div>
                        </button>
                        <button name="action_view_project" type="object" class="oe_stat_button" icon="fa-sitemap" invisible="not project_id">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Project</span>
                            </div>
                        </button>
                        <button name="action_view_wbs" type="object" class="oe_stat_button" icon="fa-tasks" invisible="not wbs_id">
                            <div class="o_stat_info">
                                <span class="o_stat_text">WBS</span>
                            </div>
                        </button>
                        <button name="action_view_attachments" type="object" class="oe_stat_button" icon="fa-paperclip">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Attachments</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                        <div><field name="ref" readonly="1"/></div>
                    </div>
                    <group>
                        <group string="Expense Details">
                            <field name="project_id"/>
                            <field name="wbs_id"/>
                            <field name="partner_id"/>
                            <field name="date"/>
                            <field name="category_id"/>
                        </group>
                        <group string="Amount &amp; Approval">
                            <field name="amount"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="employee_id"/>
                            <field name="approved_by" readonly="1"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Expense Action -->
    <record id="action_construction_expense" model="ir.actions.act_window">
        <field name="name">Expenses</field>
        <field name="res_model">construction.expense</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Expense Category Action -->
    <record id="action_construction_expense_category" model="ir.actions.act_window">
        <field name="name">Expense Categories</field>
        <field name="res_model">construction.expense.category</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
