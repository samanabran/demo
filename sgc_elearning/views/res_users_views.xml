<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Extend res.users with e-learning approval field -->
    <record id="view_res_users_form_elearning" model="ir.ui.view">
        <field name="name">res.users.form.elearning</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='other_preferences']" position="inside">
                <field name="allowed_to_learn" string="Allowed to Learn"/>
            </xpath>
        </field>
    </record>
</odoo>
