<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- KYC Application: User sees own records only -->
    <record id="rule_kyc_application_user_own" model="ir.rule">
        <field name="name">KYC Application: User sees own</field>
        <field name="model_id" ref="model_kyc_application"/>
        <field name="groups" eval="[(4, ref('group_kyc_user'))]"/>
        <field name="domain_force">[('partner_id.user_ids', 'in', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- KYC Application: Compliance Officers see all records -->
    <record id="rule_kyc_application_approver_all" model="ir.rule">
        <field name="name">KYC Application: Approver sees all</field>
        <field name="model_id" ref="model_kyc_application"/>
        <field name="groups" eval="[(4, ref('group_kyc_approver'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>
</odoo>
