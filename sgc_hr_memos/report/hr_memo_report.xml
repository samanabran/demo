<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Paper Format -->
    <record id="paperformat_hr_memo" model="report.paperformat">
        <field name="name">HR Memo A4</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">5</field>
        <field name="margin_bottom">5</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <!-- Report Action -->
    <record id="action_report_hr_memo" model="ir.actions.report">
        <field name="name">Print Memo</field>
        <field name="model">hr.memo</field>
        <field name="report_type">qweb-pdf</field>
<field name="report_name">sgc_hr_memos.report_hr_memo</field>
<field name="report_file">sgc_hr_memos.report_hr_memo</field>
        <field name="print_report_name">'Memo - %s' % (object.memo_reference or object.name)</field>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_hr_memo"/>
    </record>
</odoo>
