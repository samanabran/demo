<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Work Order List View -->
    <record id="view_construction_work_order_list" model="ir.ui.view">
        <field name="name">construction.work.order.list</field>
        <field name="model">construction.work.order</field>
        <field name="arch" type="xml">
            <list>
                <field name="ref"/>
                <field name="name"/>
                <field name="project_id"/>
                <field name="wbs_id"/>
                <field name="foreman_id"/>
                <field name="planned_start"/>
                <field name="planned_end"/>
                <field name="priority" widget="priority"/>
                <field name="state" widget="badge"
                    decoration-success="state in ('confirmed', 'done')"
                    decoration-info="state == 'in_progress'"
                    decoration-danger="state == 'cancelled'"
                    decoration-warning="state == 'draft'"/>
            </list>
        </field>
    </record>

    <!-- Work Order Form View -->
    <record id="view_construction_work_order_form" model="ir.ui.view">
        <field name="name">construction.work.order.form</field>
        <field name="model">construction.work.order</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object" string="Confirm"
                        invisible="state != 'draft'" class="btn-success"/>
                    <button name="action_start" type="object" string="Start"
                        invisible="state != 'confirmed'" class="btn-primary"/>
                    <button name="action_done" type="object" string="Mark Done"
                        invisible="state != 'in_progress'" class="btn-primary"/>
                    <button name="action_cancel" type="object" string="Cancel"
                        invisible="state not in ('draft', 'confirmed', 'in_progress')"
                        class="btn-danger"/>
                    <button name="action_reset" type="object" string="Reset to Draft"
                        invisible="state != 'cancelled'"
                        class="btn-warning"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                        <div><field name="ref" readonly="1"/> | Priority: <field name="priority" widget="priority"/></div>
                    </div>
                    <group>
                        <group string="Details">
                            <field name="project_id"/>
                            <field name="wbs_id"/>
                            <field name="foreman_id"/>
                        </group>
                        <group string="Schedule">
                            <field name="planned_start"/>
                            <field name="planned_end"/>
                            <field name="actual_start"/>
                            <field name="actual_end"/>
                        </group>
                    </group>
                    <group string="Cost">
                        <group>
                            <field name="planned_cost"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="actual_cost"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                        <page string="Material Requisitions">
                            <field name="material_requisition_ids" widget="one2many">
                                <list>
                                    <field name="ref"/>
                                    <field name="name"/>
                                    <field name="date_requested"/>
                                    <field name="total_estimated_cost"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Work Order Action -->
    <record id="action_construction_work_order" model="ir.actions.act_window">
        <field name="name">Work Orders</field>
        <field name="res_model">construction.work.order</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
