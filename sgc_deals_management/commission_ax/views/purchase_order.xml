<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_purchase_order_commission_form" model="ir.ui.view">
            <field name="name">purchase.order.commission.form</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">
                <field name="partner_id" position="after">
                    <field name="is_commission_payment"/>
                    <field name="commission_id" invisible="not is_commission_payment"/>
                </field>
            </field>
        </record>
    </data>
</odoo>
