<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_commission_main" model="ir.actions.act_window">
            <field name="name">Commissions</field>
            <field name="res_model">commission.main</field>
            <field name="view_mode">list,form</field>
            <field name="help">Manage sales commissions</field>
        </record>

        <record id="action_commission_main_pending" model="ir.actions.act_window">
            <field name="name">Pending Commissions</field>
            <field name="res_model">commission.main</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('state', '=', 'confirmed')]</field>
        </record>
    </data>
</odoo>
