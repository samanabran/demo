<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_commission_main_tree" model="ir.ui.view">
            <field name="name">commission.main.tree</field>
            <field name="model">commission.main</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="partner_id"/>
                    <field name="commission_type"/>
                    <field name="amount"/>
                    <field name="state"/>
                    <field name="date"/>
                </list>
            </field>
        </record>

        <record id="view_commission_main_form" model="ir.ui.view">
            <field name="name">commission.main.form</field>
            <field name="model">commission.main</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="partner_id"/>
                                <field name="commission_type"/>
                                <field name="amount"/>
                                <field name="percentage" invisible="commission_type != 'percentage'"/>
                            </group>
                            <group>
                                <field name="state"/>
                                <field name="date"/>
                                <field name="sale_order_id"/>
                                <field name="purchase_order_id"/>
                            </group>
                        </group>
                        <notebook>
                            <page name="notes" string="Notes">
                                <field name="notes"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_commission_main_search" model="ir.ui.view">
            <field name="name">commission.main.search</field>
            <field name="model">commission.main</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="partner_id"/>
                    <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                    <filter name="confirmed" string="Confirmed" domain="[('state','=','confirmed')]"/>
                    <filter name="paid" string="Paid" domain="[('state','=','paid')]"/>
                </search>
            </field>
        </record>
    </data>
</odoo>
