<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Unit List View ─── -->
    <record id="view_realestate_unit_list" model="ir.ui.view">
        <field name="name">realestate.unit.list</field>
        <field name="model">realestate.unit</field>
        <field name="arch" type="xml">
            <list string="Units"
                  decoration-success="state == 'available'"
                  decoration-warning="state == 'reserved'"
                  decoration-danger="state == 'sold'"
                  decoration-muted="state == 'unavailable'">
                <field name="name" string="Unit No."/>
                <field name="project_id"/>
                <field name="unit_type"/>
                <field name="floor"/>
                <field name="bedrooms"/>
                <field name="bathrooms"/>
                <field name="built_up_area" string="BUA (sqm)"/>
                <field name="plot_area" string="Plot (sqm)" optional="hide"/>
                <field name="list_price" widget="monetary"/>
                <field name="currency_id" invisible="1"/>
                <field name="deal_count"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'available'"
                       decoration-warning="state == 'reserved'"
                       decoration-danger="state == 'sold'"
                       decoration-muted="state == 'unavailable'"/>
            </list>
        </field>
    </record>

    <!-- ─── Unit Form View ─── -->
    <record id="view_realestate_unit_form" model="ir.ui.view">
        <field name="name">realestate.unit.form</field>
        <field name="model">realestate.unit</field>
        <field name="arch" type="xml">
            <form string="Unit">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="available,reserved,sold"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object"
                                name="action_view_deals" icon="fa-handshake-o">
                            <field name="deal_count" widget="statinfo" string="Deals"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Unit Number (e.g. 101, A-205)"/></h1>
                    </div>
                    <group>
                        <group string="Unit Details">
                            <field name="project_id"/>
                            <field name="unit_type"/>
                            <field name="floor"/>
                            <field name="list_price"/>
                            <field name="currency_id"/>
                        </group>
                        <group string="Dimensions">
                            <field name="plot_area"/>
                            <field name="built_up_area"/>
                            <field name="balcony_area"/>
                            <field name="bedrooms"/>
                            <field name="bathrooms"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description"/>
                        </page>
                        <page string="Features &amp; Notes" name="features">
                            <field name="features" placeholder="Parking, pool view, furnished, etc."/>
                            <separator string="Internal Notes"/>
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ─── Unit Search View ─── -->
    <record id="view_realestate_unit_search" model="ir.ui.view">
        <field name="name">realestate.unit.search</field>
        <field name="model">realestate.unit</field>
        <field name="arch" type="xml">
            <search string="Units">
                <field name="name" string="Unit" filter_domain="['|', ('name', 'ilike', self), ('project_id.name', 'ilike', self)]"/>
                <field name="project_id"/>
                <field name="unit_type"/>
                <filter string="Available" name="available" domain="[('state', '=', 'available')]"/>
                <filter string="Reserved" name="reserved" domain="[('state', '=', 'reserved')]"/>
                <filter string="Sold" name="sold" domain="[('state', '=', 'sold')]"/>
                <separator/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                <group>
                    <filter string="Project" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Unit Type" name="group_type" context="{'group_by': 'unit_type'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ─── Unit Action ─── -->
    <record id="action_realestate_unit" model="ir.actions.act_window">
        <field name="name">Units</field>
        <field name="res_model">realestate.unit</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_realestate_unit_search"/>
        <field name="context">{'search_default_available': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Add your first unit</p>
            <p>Track individual units within projects: pricing, dimensions, and deal history.</p>
        </field>
    </record>

</odoo>
