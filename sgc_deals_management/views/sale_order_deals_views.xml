<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Deals List View (dedicated, domain-filtered) ─── -->
    <record id="view_sale_order_deals_list" model="ir.ui.view">
        <field name="name">sale.order.deals.list</field>
        <field name="model">sale.order</field>
        <field name="arch" type="xml">
            <list string="Deals"
                  decoration-muted="state == 'cancel'"
                  decoration-success="state == 'sale'">
                <field name="name" string="Deal Ref"/>
                <field name="deal_type"/>
                <field name="sales_type"/>
                <field name="deal_project_id" string="Project"/>
                <field name="unit_id" string="Unit"/>
                <field name="primary_buyer_id" string="Buyer"/>
                <field name="broker_id" string="Broker"/>
                <field name="deal_sales_value" string="Unit Value" widget="monetary"/>
                <field name="deal_commission_rate" string="Comm %"/>
                <field name="commission_amount" string="Commission" widget="monetary"/>
                <field name="commission_paid" string="Paid" widget="boolean_toggle"/>
                <field name="deal_date" string="Deal Date"/>
                <field name="currency_id" invisible="1"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'sent'"
                       decoration-success="state == 'sale'"
                       decoration-danger="state == 'cancel'"/>
            </list>
        </field>
    </record>

    <!-- ─── Deals Form Inherit (adds Deal Details tab to sale.order) ─── -->
    <record id="view_sale_order_deals_form" model="ir.ui.view">
        <field name="name">sale.order.deals.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='order_lines']" position="before">
                <page string="Deal Details" name="deal_details"
                      invisible="not is_deal">
                    <group>
                        <group string="Classification">
                            <field name="is_deal"/>
                            <field name="deal_type"/>
                            <field name="sales_type"/>
                        </group>
                        <group string="Commission">
                            <field name="deal_commission_rate"/>
                            <field name="commission_amount" widget="monetary"/>
                            <field name="commission_paid"/>
                        </group>
                    </group>
                    <group>
                        <group string="Property">
                            <field name="deal_project_id" string="Project"/>
                            <field name="unit_id" string="Unit"
                                   domain="[('project_id', '=', deal_project_id)]"/>
                            <field name="deal_sales_value" widget="monetary"/>
                        </group>
                        <group string="Parties">
                            <field name="primary_buyer_id"/>
                            <field name="secondary_buyer_id"/>
                            <field name="broker_id"/>
                        </group>
                    </group>
                    <group string="Dates">
                        <group>
                            <field name="deal_date"/>
                            <field name="booking_date"/>
                        </group>
                    </group>
                    <group string="Payment Terms">
                        <field name="payment_terms_summary" nolabel="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- ─── Deals Search View ─── -->
    <record id="view_sale_order_deals_search" model="ir.ui.view">
        <field name="name">sale.order.deals.search</field>
        <field name="model">sale.order</field>
        <field name="arch" type="xml">
            <search string="Deals">
                <field name="name" string="Deal Ref"/>
                <field name="primary_buyer_id" string="Buyer"/>
                <field name="deal_project_id" string="Project"/>
                <field name="unit_id" string="Unit"/>
                <field name="broker_id" string="Broker"/>
                <filter string="Confirmed" name="confirmed" domain="[('state', '=', 'sale')]"/>
                <filter string="Off-Plan" name="offplan" domain="[('deal_type', '=', 'offplan')]"/>
                <filter string="Resale" name="resale" domain="[('deal_type', '=', 'resale')]"/>
                <filter string="Rental" name="rental" domain="[('deal_type', '=', 'rental')]"/>
                <separator/>
                <filter string="Commission Unpaid" name="unpaid"
                        domain="[('commission_paid', '=', False), ('state', '=', 'sale')]"/>
                <group>
                    <filter string="Deal Type" name="group_deal_type" context="{'group_by': 'deal_type'}"/>
                    <filter string="Project" name="group_project" context="{'group_by': 'deal_project_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Broker" name="group_broker" context="{'group_by': 'broker_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ─── Deals Action ─── -->
    <record id="action_sale_order_deals" model="ir.actions.act_window">
        <field name="name">All Deals</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_sale_order_deals_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('sale.view_order_form')}),
        ]"/>
        <field name="domain">[('is_deal', '=', True)]</field>
        <field name="search_view_id" ref="view_sale_order_deals_search"/>
        <field name="context">{'default_is_deal': True}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first real estate deal</p>
            <p>Track offplan, resale and rental deals with commissions, buyers, and project assignments.</p>
        </field>
    </record>

    <!-- ─── Deals Customers Action ─── -->
    <record id="action_deals_customers" model="ir.actions.act_window">
        <field name="name">Buyers / Customers</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('customer_rank', '>', 0)]</field>
        <field name="context">{'default_customer_rank': 1}</field>
    </record>

</odoo>
