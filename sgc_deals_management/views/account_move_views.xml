<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Modify customer invoice form to show deal information in a new tab -->
    <record id="view_move_form_deal_info" model="ir.ui.view">
        <field name="name">account.move.form.deal.info</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            <!-- Add a new tab "Deal Details" in the notebook -->
            <xpath expr="//notebook" position="inside">
                <page string="Deal Details" name="deal_details">
                    <group col="2">
                        <group string="Deal Information">
                            <field name="sales_type" readonly="1" />
                            <field name="sale_order_deal_id" widget="many2one" readonly="1" />
                            <field name="booking_date" readonly="1" />
                            <field name="primary_buyer_id" readonly="1" />
                            <field name="secondary_buyer_id" readonly="1" />
                        </group>
                        <group string="Deal Location &amp; Value">
                            <field name="project_id" readonly="1" />
                            <field name="unit_id" readonly="1" />
                            <field name="deal_sales_value" readonly="1" />
                            <field name="deal_commission_rate" readonly="1" />
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Add deal information to invoice tree view -->
    <record id="view_move_tree_deal_info" model="ir.ui.view">
        <field name="name">account.move.tree.deal.info</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_tree" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='ref']" position="after">
                <field name="sale_order_deal_id" optional="hide" />
                <field name="project_id" optional="hide" />
                <field name="unit_id" optional="hide" />
                <field name="primary_buyer_id" optional="hide" />
            </xpath>
        </field>
    </record>
</odoo>
