<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Project List View ─── -->
    <record id="view_realestate_project_list" model="ir.ui.view">
        <field name="name">realestate.project.list</field>
        <field name="model">realestate.project</field>
        <field name="arch" type="xml">
            <list string="Projects" decoration-muted="state == 'delivered'">
                <field name="name"/>
                <field name="code"/>
                <field name="project_type"/>
                <field name="developer_id"/>
                <field name="city"/>
                <field name="country_id"/>
                <field name="start_date"/>
                <field name="expected_completion_date"/>
                <field name="unit_count"/>
                <field name="deal_count"/>
                <field name="total_project_value" widget="monetary" optional="show"/>
                <field name="currency_id" invisible="1"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'planned'"
                       decoration-warning="state == 'construction'"
                       decoration-success="state == 'completed'"
                       decoration-muted="state == 'delivered'"/>
            </list>
        </field>
    </record>

    <!-- ─── Project Form View ─── -->
    <record id="view_realestate_project_form" model="ir.ui.view">
        <field name="name">realestate.project.form</field>
        <field name="model">realestate.project</field>
        <field name="arch" type="xml">
            <form string="Project">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="planned,construction,completed,delivered"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object"
                                name="action_view_units" icon="fa-building-o">
                            <field name="unit_count" widget="statinfo" string="Units"/>
                        </button>
                        <button class="oe_stat_button" type="object"
                                name="action_view_deals" icon="fa-handshake-o">
                            <field name="deal_count" widget="statinfo" string="Deals"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Project Name"/></h1>
                        <label for="code"/>
                        <h3><field name="code" placeholder="Project Code"/></h3>
                    </div>
                    <group>
                        <group string="Project Info">
                            <field name="project_type"/>
                            <field name="developer_id"/>
                            <field name="currency_id"/>
                            <field name="total_project_value" widget="monetary"/>
                        </group>
                        <group string="Timeline">
                            <field name="start_date"/>
                            <field name="expected_completion_date"/>
                            <field name="completion_date"/>
                        </group>
                    </group>
                    <group string="Location">
                        <group>
                            <field name="street"/>
                            <field name="street2"/>
                            <field name="city"/>
                        </group>
                        <group>
                            <field name="zip"/>
                            <field name="state_id"/>
                            <field name="country_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Units" name="units">
                            <field name="unit_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="unit_type"/>
                                    <field name="floor"/>
                                    <field name="built_up_area"/>
                                    <field name="list_price" widget="monetary"/>
                                    <field name="currency_id" invisible="1"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'available'"
                                           decoration-warning="state == 'reserved'"
                                           decoration-danger="state == 'sold'"/>
                                </list>
                            </field>
                        </page>
                        <page string="Description" name="description">
                            <field name="description"/>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ─── Project Kanban View ─── -->
    <record id="view_realestate_project_kanban" model="ir.ui.view">
        <field name="name">realestate.project.kanban</field>
        <field name="model">realestate.project</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="id"/>
                <field name="name"/>
                <field name="code"/>
                <field name="project_type"/>
                <field name="state"/>
                <field name="unit_count"/>
                <field name="deal_count"/>
                <field name="total_project_value"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="card" class="oe_kanban_global_click">
                        <div class="o_kanban_record_top">
                            <div class="o_kanban_record_headings">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <small class="o_kanban_record_subtitle text-muted">
                                    <field name="code"/>
                                </small>
                            </div>
                        </div>
                        <div class="o_kanban_record_body">
                            <span><i class="fa fa-building-o" title="Units"/> <field name="unit_count"/> Units</span>
                            <span class="ms-2"><i class="fa fa-handshake-o" title="Deals"/> <field name="deal_count"/> Deals</span>
                        </div>
                        <div class="o_kanban_record_bottom">
                            <div class="oe_kanban_bottom_left">
                                <field name="total_project_value" widget="monetary"/>
                            </div>
                            <div class="oe_kanban_bottom_right">
                                <field name="state"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ─── Project Search View ─── -->
    <record id="view_realestate_project_search" model="ir.ui.view">
        <field name="name">realestate.project.search</field>
        <field name="model">realestate.project</field>
        <field name="arch" type="xml">
            <search string="Projects">
                <field name="name" string="Project" filter_domain="['|', ('name', 'ilike', self), ('code', 'ilike', self)]"/>
                <field name="developer_id"/>
                <field name="city"/>
                <filter string="Under Construction" name="construction" domain="[('state', '=', 'construction')]"/>
                <filter string="Planned" name="planned" domain="[('state', '=', 'planned')]"/>
                <filter string="Completed" name="completed" domain="[('state', '=', 'completed')]"/>
                <separator/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                <group>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Type" name="group_type" context="{'group_by': 'project_type'}"/>
                    <filter string="Developer" name="group_developer" context="{'group_by': 'developer_id'}"/>
                    <filter string="Country" name="group_country" context="{'group_by': 'country_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ─── Project Action ─── -->
    <record id="action_realestate_project" model="ir.actions.act_window">
        <field name="name">Projects</field>
        <field name="res_model">realestate.project</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_realestate_project_search"/>
        <field name="context">{'search_default_construction': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first real estate project</p>
            <p>Track offplan and development projects with units, deals, and timelines.</p>
        </field>
    </record>

</odoo>
